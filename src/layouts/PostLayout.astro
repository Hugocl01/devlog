---
import BaseLayout from "@/layouts/main.astro";
import type { CollectionEntry } from "astro:content";
import { Badge } from "@/components/ui/badge";
import { ChevronLeft, ChevronRight, Link2, Check } from "@lucide/astro";
import { Image } from "astro:assets";

import { tagUrl } from "@/utils/tag";

type Cover =
  | string
  | {
      src: string;
      caption?: string;
    };

type PostLayoutProps = {
  id?: string;
  title: string;
  description?: string;
  date: string | Date;
  author?: string;
  tags?: string[];
  cover?: Cover;
  prev?: CollectionEntry<"posts"> | null;
  next?: CollectionEntry<"posts"> | null;
  readingTime?: number;
};

const { id, title, description, date, author, tags, cover, prev, next, readingTime } =
  Astro.props as PostLayoutProps;

const isoDate = date ? new Date(date).toISOString() : undefined;
const formattedDate = date
  ? new Date(date).toLocaleDateString("es-ES", { dateStyle: "long" })
  : "Fecha desconocida";
const coverImage = typeof cover === "string" ? cover : cover?.src;
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  image={coverImage}
>
  <Fragment slot="head">
    {isoDate && <meta property="article:published_time" content={isoDate} />}
    {author && <meta property="article:author" content={author} />}
    {(tags ?? []).length > 0 && <meta property="article:tag" content={(tags ?? []).join(",")} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "datePublished": isoDate,
      "url": Astro.url.toString(),
      ...(author && { "author": { "@type": "Person", "name": author } }),
      ...(coverImage && { "image": new URL(coverImage, Astro.site).toString() }),
    })} />
  </Fragment>
  <article class="max-w-4xl mx-auto px-4 py-20 sm:py-24">
    {
      cover && (
        <figure class="mb-12 max-h-[400px] overflow-hidden rounded-xl">
          {typeof cover === "string" ? (
            <Image
              src={cover}
              alt={`Imagen de portada del post: ${title}`}
              width={1200}
              height={630}
              class="w-full object-cover"
              transition:name={`img-${id}`}
            />
          ) : (
            <Image
              src={cover.src as any}
              alt={`Imagen de portada del post: ${title}`}
              width={1200}
              height={630}
              class="w-full object-cover"
              transition:name={`img-${id}`}
            />
          )}

          {typeof cover !== "string" && cover.caption && (
            <figcaption class="mt-2 text-center text-sm text-muted-foreground">
              {cover.caption}
            </figcaption>
          )}
        </figure>
      )
    }

    <header
      class="max-w-3xl mx-auto mb-12 pb-6 border-b border-gray-200/50 dark:border-gray-700/50 reveal"
    >
      <div
        class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 text-sm text-muted-foreground mb-4 reveal stagger-1"
      >
        <time class="tabular-nums" datetime={date ? new Date(date).toISOString() : undefined}>
          Publicado el {formattedDate}
          {readingTime && ` • ${readingTime} min de lectura`}
        </time>

        {
          author && (
            <p class="font-medium">
              Por <strong>{author}</strong>
            </p>
          )
        }
      </div>

      <h1
        class="text-4xl sm:text-5xl font-extrabold tracking-tight leading-tight mb-4 reveal stagger-2"
        transition:name={`title-${id}`}
      >
        {title}
      </h1>

      <div class="flex flex-wrap gap-2 reveal stagger-3">
        {
          (tags ?? []).map((tag) => (
            <a
              href={`/tags/${tagUrl(tag)}`}
              class="relative z-20 hover:opacity-80 transition-all duration-300 hover:scale-105 active:scale-95"
            >
              <Badge variant="secondary">{tag}</Badge>
            </a>
          ))
        }
      </div>
    </header>

    <div
      class="max-w-3xl mx-auto prose prose-lg sm:prose-base dark:prose-invert prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-gray-100 prose-a:text-blue-600 hover:prose-a:underline reveal stagger-4"
    >
      <slot />
    </div>

    <div
      class="max-w-3xl mx-auto mt-8 py-5 border-t border-gray-200/50 dark:border-gray-700/50 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <p class="font-medium text-foreground">¿Te ha gustado? ¡Compártelo!</p>
      <div class="flex gap-2">
        <a
          href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(Astro.url.toString())}&title=${encodeURIComponent(title)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors group"
          aria-label="Compartir en LinkedIn"
        >
          <svg
            class="h-4 w-4 transition-transform group-hover:scale-110"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
        <button
          id="copy-link-btn"
          data-url={Astro.url.toString()}
          class="inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-md border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors"
          aria-label="Copiar enlace"
        >
          <Link2 class="h-4 w-4" id="copy-icon-link" />
          <Check class="h-4 w-4 text-green-500 hidden" id="copy-icon-check" />
        </button>
      </div>
    </div>

    <nav
      class="max-w-3xl mx-auto mt-8 pt-8 border-t border-gray-200/50 dark:border-gray-700/50 flex justify-between gap-4"
    >
      {
        prev ? (
          <a
            href={`/blog/${prev.id}`}
            class="group block flex-1 rounded-lg border border-border bg-card p-5 transition-all duration-500 ease-premium
             hover:shadow-premium hover:border-primary/30 hover:-translate-y-1 hover:scale-[1.05]
             focus-within:ring-2 focus-within:ring-primary focus-within:ring-offset-2 focus:outline-none max-w-sm reveal stagger-5"
          >
            <div class="flex flex-col">
              <span class="text-xs text-muted-foreground mb-1">Anterior</span>

              <h3 class="text-lg font-semibold text-foreground transition-colors group-hover:text-primary">
                {prev.data.title}
              </h3>

              <span
                class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary
                 transition-all group-hover:gap-2"
              >
                <ChevronLeft
                  class="h-4 w-4 transition-transform group-hover:-translate-x-1"
                  stroke-width="2.5"
                />
                Leer anterior
              </span>
            </div>
          </a>
        ) : (
          <div class="flex-1 max-w-sm" />
        )
      }

      {
        next ? (
          <a
            href={`/blog/${next.id}`}
            class="group block flex-1 rounded-lg border border-border bg-card p-5 transition-all duration-500 ease-premium
             hover:shadow-premium hover:border-primary/30 hover:-translate-y-1 hover:scale-[1.05]
             focus-within:ring-2 focus-within:ring-primary focus-within:ring-offset-2 focus:outline-none text-right max-w-sm reveal stagger-5"
          >
            <div class="flex flex-col items-end">
              <span class="text-xs text-muted-foreground mb-1">Siguiente</span>

              <h3 class="text-lg font-semibold text-foreground transition-colors group-hover:text-primary">
                {next.data.title}
              </h3>

              <span
                class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary
                 transition-all group-hover:gap-2"
              >
                Leer siguiente
                <ChevronRight
                  class="h-4 w-4 transition-transform group-hover:translate-x-1"
                  stroke-width="2.5"
                />
              </span>
            </div>
          </a>
        ) : (
          <div class="flex-1 max-w-sm" />
        )
      }
    </nav>
  </article>
</BaseLayout>

<script>
  const setupCopyBtn = () => {
    const copyBtn = document.getElementById("copy-link-btn");
    if (!copyBtn || copyBtn.dataset.listener) return;
    copyBtn.dataset.listener = "true";

    copyBtn.addEventListener("click", async () => {
      const url = copyBtn.getAttribute("data-url");
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        const iconLink = document.getElementById("copy-icon-link");
        const iconCheck = document.getElementById("copy-icon-check");
        if (iconLink && iconCheck) {
          iconLink.classList.add("hidden");
          iconCheck.classList.remove("hidden");
          setTimeout(() => {
            iconLink.classList.remove("hidden");
            iconCheck.classList.add("hidden");
          }, 2000);
        }
      } catch (e) {
        console.error("Error al copiar enlace:", e);
      }
    });
  };

  setupCopyBtn();
  document.addEventListener("astro:page-load", setupCopyBtn);
</script>
