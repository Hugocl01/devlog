---
export const prerender = false;
import BaseLayout from "@/layouts/main.astro";

const { social_github, social_linkedin, contact_email } = Astro.locals.settings;

const GITHUB_ICON   = "M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z";
const LINKEDIN_ICON = "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z";

const socialLinks = [
  ...(social_github   ? [{ name: "GitHub",  href: social_github,   icon: GITHUB_ICON   }] : []),
  ...(social_linkedin ? [{ name: "LinkedIn", href: social_linkedin, icon: LINKEDIN_ICON }] : []),
];
---

<BaseLayout
  title="Aviso Legal"
  description="Aviso legal de DevLog: información sobre el titular, tratamiento de datos, propiedad intelectual y normativa aplicable conforme a la legislación española."
>
  <section class="max-w-5xl mx-auto py-16 px-4">
    <header class="text-center mb-16">
      <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight mb-4 text-foreground">
        Aviso Legal
      </h1>
      <p class="text-lg text-muted-foreground">
        Información legal sobre la titularidad, tratamiento de datos y condiciones de uso de este
        sitio.
      </p>
      <p class="text-sm mt-2 text-muted-foreground">Última actualización: 19 de junio de 2026</p>
    </header>

    <div
      class="max-w-3xl mx-auto flex flex-col gap-8 prose prose-lg dark:prose-invert [&_h2]:font-bold [&_h3]:font-semibold [&_h3]:text-base [&_h3]:mt-4"
    >

      <!-- 1. DATOS DEL TITULAR -->
      <div>
        <h2>1. Datos del titular e información general</h2>
        <p>
          En cumplimiento del artículo 10 de la Ley 34/2002, de 11 de julio, de Servicios de la
          Sociedad de la Información y de Comercio Electrónico (LSSI-CE), se facilitan los
          siguientes datos identificativos:
        </p>
        <ul>
          <li><strong>Titular:</strong> Hugo Cayón Laso</li>
          <li><strong>Carácter:</strong> Persona física, actividad sin carácter comercial</li>
          <li>
            <strong>Correo electrónico de contacto:</strong>{" "}
            {contact_email ? <a href={`mailto:${contact_email}`}>{contact_email}</a> : "—"}
          </li>
          <li><strong>País:</strong> España</li>
          <li>
            <strong>Sitio web:</strong> DevLog — blog personal sobre desarrollo web y tecnología
          </li>
        </ul>
        <p>
          El titular no ejerce actividad económica o profesional a través de este sitio. DevLog es
          un blog personal de carácter divulgativo y comunitario, sin fines lucrativos.
        </p>
      </div>

      <!-- 2. OBJETO Y SERVICIOS -->
      <div>
        <h2>2. Objeto y servicios del sitio</h2>
        <p>
          DevLog es un blog personal que tiene por objeto la publicación de artículos y
          actualizaciones sobre desarrollo web, tecnología y proyectos personales. El sitio
          incorpora las siguientes funcionalidades:
        </p>
        <ul>
          <li>
            <strong>Contenido editorial:</strong> publicación de artículos (posts) y notas de
            proyecto (updates), organizados por etiquetas y accesibles mediante RSS.
          </li>
          <li>
            <strong>Cuentas de usuario:</strong> registro e inicio de sesión mediante correo
            electrónico y contraseña (con verificación de la dirección de correo y posibilidad de
            recuperación de contraseña), o mediante la cuenta de <strong>GitHub (OAuth)</strong>.
            Los usuarios pueden gestionar su perfil, cambiar su correo electrónico o contraseña,
            y exportar sus datos personales directamente desde su perfil.
          </li>
          <li>
            <strong>Comentarios:</strong> los usuarios registrados pueden publicar comentarios y
            respuestas en los artículos.
          </li>
          <li>
            <strong>Reacciones:</strong> los usuarios registrados pueden expresar reacciones
            (me gusta, me encanta, fuego, aplauso y wow) en los artículos.
          </li>
          <li>
            <strong>Perfil de usuario:</strong> los usuarios registrados pueden gestionar su nombre,
            foto de perfil y descripción biográfica.
          </li>
          <li>
            <strong>Analíticas de lectura:</strong> conteo de visitas por artículo mediante datos
            anonimizados.
          </li>
          <li>
            <strong>Panel de administración:</strong> para la gestión interna de contenidos,
            usuarios, etiquetas y comentarios, accesible únicamente por administradores.
          </li>
        </ul>
      </div>

      <!-- 3. PROTECCIÓN DE DATOS -->
      <div>
        <h2>3. Protección de datos personales</h2>
        <p>
          El titular trata datos personales de conformidad con el Reglamento (UE) 2016/679 del
          Parlamento Europeo y del Consejo (RGPD) y la Ley Orgánica 3/2018, de 5 de diciembre, de
          Protección de Datos Personales y garantía de los derechos digitales (LOPDGDD). La
          información detallada sobre qué datos se recogen, con qué finalidad, durante cuánto tiempo
          y cómo ejercer tus derechos se encuentra en la{" "}
          <a href="/privacy">Política de Privacidad</a>.
        </p>

        <h3>3.1 Responsable del tratamiento</h3>
        <p>
          <strong>Hugo Cayón Laso</strong>{contact_email && <>{" "}— <a href={`mailto:${contact_email}`}>{contact_email}</a></>}
        </p>

        <h3>3.2 Datos tratados, finalidades y base legitimadora</h3>
        <p>
          Los datos personales recopilados se limitan a los estrictamente necesarios para cada
          finalidad:
        </p>

        <div class="overflow-x-auto not-prose my-4">
          <table
            class="w-full text-sm border border-border/50 rounded-xl overflow-hidden"
          >
            <thead class="bg-secondary/40 text-foreground font-semibold">
              <tr>
                <th class="px-4 py-3 text-left">Datos</th>
                <th class="px-4 py-3 text-left">Finalidad</th>
                <th class="px-4 py-3 text-left">Base legitimadora</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border/40">
              <tr class="bg-card/30">
                <td class="px-4 py-3">Nombre, correo electrónico, contraseña (hash)</td>
                <td class="px-4 py-3"
                  >Creación y gestión de la cuenta de usuario; envío de correos de verificación y
                  recuperación de contraseña</td
                >
                <td class="px-4 py-3"
                  >Ejecución de la relación de servicio (art. 6.1.b RGPD)</td
                >
              </tr>
              <tr class="bg-card/10">
                <td class="px-4 py-3"
                  >Token de sesión, dirección IP, navegador (user-agent), fecha y hora</td
                >
                <td class="px-4 py-3"
                  >Autenticación y mantenimiento de sesiones activas; seguridad</td
                >
                <td class="px-4 py-3"
                  >Ejecución de la relación de servicio (art. 6.1.b RGPD); interés legítimo en la
                  seguridad del servicio (art. 6.1.f RGPD)</td
                >
              </tr>
              <tr class="bg-card/30">
                <td class="px-4 py-3">Avatar y biografía (opcionales)</td>
                <td class="px-4 py-3">Personalización del perfil de usuario</td>
                <td class="px-4 py-3">Consentimiento del usuario (art. 6.1.a RGPD)</td>
              </tr>
              <tr class="bg-card/10">
                <td class="px-4 py-3"
                  >Hash irreversible de IP y navegador (user-agent)</td
                >
                <td class="px-4 py-3"
                  >Estadísticas de lectura por artículo y actualización (conteo de visitas únicas
                  aproximadas). Los datos se anonimizan de forma que no permiten identificar
                  individualmente al visitante. La IP real nunca se almacena.</td
                >
                <td class="px-4 py-3"
                  >Interés legítimo del titular (art. 6.1.f RGPD). El uso de un hash irreversible
                  impide la reidentificación</td
                >
              </tr>
              <tr class="bg-card/30">
                <td class="px-4 py-3">Contenido de comentarios y reacciones</td>
                <td class="px-4 py-3"
                  >Provisión de las funcionalidades de comunidad; moderación de contenido</td
                >
                <td class="px-4 py-3">Ejecución de la relación de servicio (art. 6.1.b RGPD)</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p>
          Las contraseñas se almacenan exclusivamente en formato hash irreversible mediante un
          algoritmo de hash seguro (bcrypt). Nunca se guardan ni se transmiten en texto plano.
        </p>

        <h3>3.3 Plazos de conservación</h3>
        <ul>
          <li>
            <strong>Datos de cuenta (nombre, correo, contraseña):</strong> durante la vigencia de
            la cuenta. Tras la eliminación de la cuenta, los datos identificativos se suprimen de
            forma inmediata, salvo obligación legal de conservación.
          </li>
          <li>
            <strong>Sesiones:</strong> hasta su fecha de expiración o hasta que el usuario las
            revoque manualmente.
          </li>
          <li>
            <strong>Registros técnicos de autenticación (IP, user-agent):</strong> se conservan
            asociados a las sesiones activas. Se eliminan cuando la sesión expira o se revoca.
          </li>
          <li>
            <strong>Analíticas de visitas (hash de IP, país):</strong> de forma indefinida como
            datos estadísticos; al tratarse de un hash irreversible, no constituyen datos personales
            en el sentido del RGPD una vez procesados.
          </li>
          <li>
            <strong>Comentarios y reacciones:</strong> mientras la cuenta del usuario esté activa.
            Tras la eliminación de la cuenta, los comentarios pueden conservarse en formato
            anonimizado para preservar la coherencia de los hilos de conversación.
          </li>
        </ul>

        <h3>3.4 Destinatarios y encargados del tratamiento</h3>
        <p>
          Los datos personales no se ceden a terceros con fines comerciales ni de marketing. El
          acceso a los datos queda limitado a:
        </p>
        <ul>
          <li>
            <strong>Proveedor de alojamiento web (hosting):</strong> actúa como encargado del
            tratamiento conforme a sus condiciones contractuales. Por razones técnicas, puede
            registrar metadatos de red (IP de origen, marcas de tiempo) en sus logs de
            infraestructura.
          </li>
          <li>
            <strong>Proveedor de servicios de correo electrónico transaccional:</strong> utilizado
            exclusivamente para el envío de correos de verificación de cuenta y recuperación de
            contraseña. Actúa como encargado del tratamiento.
          </li>
          <li>
            <strong>Autoridades competentes:</strong> en caso de obligación legal o requerimiento
            judicial.
          </li>
        </ul>

        <h3>3.5 Transferencias internacionales de datos</h3>
        <p>
          Los datos se almacenan en servidores ubicados dentro del Espacio Económico Europeo (EEE).
          En el caso de que alguno de los proveedores indicados esté establecido fuera del EEE,
          dicha transferencia se realizará únicamente a países con decisión de adecuación de la
          Comisión Europea, o amparada en garantías adecuadas conforme al artículo 46 del RGPD
          (cláusulas contractuales tipo).
        </p>

        <h3>3.6 Derechos de los interesados</h3>
        <p>
          Los usuarios tienen derecho a ejercer, en cualquier momento, los siguientes derechos
          frente al responsable del tratamiento:
        </p>
        <ul>
          <li>
            <strong>Acceso (art. 15 RGPD):</strong> conocer qué datos personales se tratan y
            obtener una copia de los mismos.
          </li>
          <li>
            <strong>Rectificación (art. 16 RGPD):</strong> corregir datos inexactos o incompletos.
            Los propios datos de perfil pueden modificarse directamente desde la sección de perfil
            de usuario.
          </li>
          <li>
            <strong>Supresión («derecho al olvido», art. 17 RGPD):</strong> solicitar la
            eliminación de los datos personales cuando, entre otras circunstancias, ya no sean
            necesarios para los fines que motivaron su recogida.
          </li>
          <li>
            <strong>Limitación del tratamiento (art. 18 RGPD):</strong> solicitar la suspensión
            del tratamiento en determinados supuestos.
          </li>
          <li>
            <strong>Portabilidad (art. 20 RGPD):</strong> recibir los datos que ha facilitado en
            un formato estructurado, de uso común y lectura mecánica.
          </li>
          <li>
            <strong>Oposición (art. 21 RGPD):</strong> oponerse al tratamiento basado en interés
            legítimo.
          </li>
        </ul>
        <p>
          Para ejercer cualquiera de estos derechos, dirígete al titular mediante correo electrónico
          {contact_email ? <> a <a href={`mailto:${contact_email}`}>{contact_email}</a></> : ""}, indicando el derecho que
          deseas ejercer y adjuntando un documento que acredite tu identidad. El titular responderá
          en el plazo máximo de un mes, prorrogable dos meses adicionales en casos de especial
          complejidad.
        </p>
        <p>
          Si consideras que el tratamiento de tus datos no es conforme a la normativa vigente,
          tienes derecho a presentar una reclamación ante la{" "}
          <strong>Agencia Española de Protección de Datos (AEPD)</strong>, autoridad de control
          competente en España, a través de su sitio web{" "}
          <a href="https://www.aepd.es" target="_blank" rel="noopener noreferrer">www.aepd.es</a>.
        </p>
      </div>

      <!-- 4. COOKIES -->
      <div>
        <h2>4. Política de cookies</h2>
        <p>
          El sitio web utiliza únicamente cookies técnicas estrictamente necesarias para el
          funcionamiento del servicio, conforme al artículo 22.2 de la LSSI-CE y las directrices
          de la AEPD sobre cookies:
        </p>
        <div class="overflow-x-auto not-prose my-4">
          <table class="w-full text-sm border border-border/50 rounded-xl overflow-hidden">
            <thead class="bg-secondary/40 text-foreground font-semibold">
              <tr>
                <th class="px-4 py-3 text-left">Cookie</th>
                <th class="px-4 py-3 text-left">Finalidad</th>
                <th class="px-4 py-3 text-left">Duración</th>
                <th class="px-4 py-3 text-left">Tipo</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border/40">
              <tr class="bg-card/30">
                <td class="px-4 py-3 font-mono text-xs">devlog_session</td>
                <td class="px-4 py-3"
                  >Token de sesión que identifica al usuario autenticado y mantiene su sesión
                  activa. Es <code>HttpOnly</code> (JavaScript no puede leerla), <code>Secure</code>
                  (solo HTTPS) y <code>SameSite=Lax</code> (protección CSRF).</td
                >
                <td class="px-4 py-3">7 días (sin «Recuérdame») o 30 días (con «Recuérdame»); o hasta que cierres sesión</td>
                <td class="px-4 py-3">Técnica necesaria — propia</td>
              </tr>
              <tr class="bg-card/10">
                <td class="px-4 py-3 font-mono text-xs">github_oauth_state</td>
                <td class="px-4 py-3"
                  >Token CSRF temporal que protege el flujo de autenticación con GitHub OAuth.
                  Se crea al iniciar el proceso y se elimina automáticamente al completarlo
                  o cancelarlo.</td
                >
                <td class="px-4 py-3">Sesión (minutos; se elimina al finalizar el proceso)</td>
                <td class="px-4 py-3">Técnica necesaria — propia</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p>
          No se utilizan cookies de publicidad, analítica de terceros ni de seguimiento
          comportamental. La preferencia de tema (claro/oscuro) se almacena en el
          <code>localStorage</code> del navegador, que no es una cookie y no se transmite al
          servidor.
        </p>
        <p>
          Las cookies estrictamente necesarias no requieren el consentimiento del usuario conforme
          a la normativa vigente, dado que son imprescindibles para la prestación del servicio
          solicitado. El usuario puede configurar su navegador para rechazar o eliminar cookies, lo
          que puede impedir el correcto funcionamiento del inicio de sesión.
        </p>
      </div>

      <!-- 5. PROPIEDAD INTELECTUAL -->
      <div>
        <h2>5. Propiedad intelectual e industrial</h2>
        <p>
          Todos los contenidos del sitio web — incluyendo textos, artículos, imágenes propias,
          logotipos, código de ejemplo y cualquier otro material publicado — son propiedad de
          <strong>Hugo Cayón Laso</strong> o se utilizan bajo la correspondiente licencia o
          autorización, estando protegidos por el Real Decreto Legislativo 1/1996, de 12 de abril,
          por el que se aprueba el texto refundido de la Ley de Propiedad Intelectual, y por la
          normativa europea e internacional de aplicación.
        </p>
        <ul>
          <li>
            Queda expresamente prohibida la reproducción total o parcial, distribución,
            comunicación pública o transformación de los contenidos sin autorización previa y por
            escrito del titular, salvo las excepciones legalmente previstas.
          </li>
          <li>
            Se permite la cita de fragmentos de los artículos, siempre que se atribuya
            correctamente la autoría y se incluya un enlace a la fuente original.
          </li>
          <li>
            El código fuente de la plataforma técnica puede estar disponible bajo una licencia
            open-source específica indicada en el repositorio de GitHub. Dicha licencia no abarca
            los contenidos editoriales (artículos, imágenes propias).
          </li>
        </ul>
      </div>

      <!-- 6. RESPONSABILIDAD -->
      <div>
        <h2>6. Limitación de responsabilidad</h2>
        <p>
          El titular no asume responsabilidad alguna derivada de:
        </p>
        <ul>
          <li>
            Los errores u omisiones en los contenidos editoriales publicados, que tienen carácter
            meramente informativo y divulgativo.
          </li>
          <li>
            La falta de disponibilidad, continuidad o funcionamiento sin interrupciones del sitio
            web por causas ajenas al control del titular (fallos de red, interrupciones del servidor,
            ataques informáticos, etc.).
          </li>
          <li>
            El contenido publicado por usuarios registrados en los comentarios, cuya
            responsabilidad recae íntegramente en quien lo publica. El titular se reserva el derecho
            de eliminar, sin previo aviso, cualquier comentario que infrinja la normativa vigente o
            estas condiciones.
          </li>
          <li>
            Los contenidos de sitios web externos enlazados desde el blog, sobre los que el titular
            no ejerce control editorial ni técnico.
          </li>
          <li>
            El uso que terceros realicen de la información publicada en el sitio.
          </li>
        </ul>
      </div>

      <!-- 7. MENORES -->
      <div>
        <h2>7. Menores de edad</h2>
        <p>
          De conformidad con el artículo 7 de la LOPDGDD, el tratamiento de datos personales de
          menores de catorce (14) años requiere el consentimiento de los titulares de la patria
          potestad o tutela. El registro en el sitio web está dirigido exclusivamente a personas
          que hayan cumplido los 14 años. El titular no recaba deliberadamente datos de menores
          de esa edad; si tuviera conocimiento de haberlo hecho de forma inadvertida, procederá
          a suprimir dichos datos sin demora.
        </p>
      </div>

      <!-- 8. LEGISLACIÓN -->
      <div>
        <h2>8. Legislación aplicable y jurisdicción</h2>
        <p>
          El presente Aviso Legal se rige íntegramente por la legislación española. La normativa
          principal de referencia es la siguiente:
        </p>
        <ul>
          <li>
            <strong>Reglamento (UE) 2016/679 (RGPD)</strong> — relativo a la protección de las
            personas físicas en lo que respecta al tratamiento de datos personales y a la libre
            circulación de estos datos.
          </li>
          <li>
            <strong>Ley Orgánica 3/2018, de 5 de diciembre (LOPDGDD)</strong> — de Protección de
            Datos Personales y garantía de los derechos digitales.
          </li>
          <li>
            <strong>Ley 34/2002, de 11 de julio (LSSI-CE)</strong> — de Servicios de la Sociedad
            de la Información y de Comercio Electrónico.
          </li>
          <li>
            <strong>Real Decreto Legislativo 1/1996 (LPI)</strong> — texto refundido de la Ley de
            Propiedad Intelectual.
          </li>
        </ul>
        <p>
          Para cualquier controversia derivada del acceso o uso del sitio web, las partes se
          someten, con renuncia expresa a cualquier otro fuero que pudiera corresponderles, a los
          juzgados y tribunales competentes conforme a la legislación española.
        </p>
      </div>

    </div>

    <div class="mt-16 text-center not-prose">
      <p class="mb-8 text-lg text-muted-foreground">
        ¿Tienes alguna consulta sobre privacidad o datos?{contact_email && <>{" "}Escríbeme a{" "}<a href={`mailto:${contact_email}`} class="text-primary hover:underline">{contact_email}</a>{" "}</>}
        {socialLinks.length > 0 && <>o contáctame a través de mis perfiles:</>}
      </p>
      <div class="inline-flex gap-8 justify-center">
        {
          socialLinks.map((social, index) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`flex h-16 w-16 items-center justify-center rounded-full bg-secondary/30 border border-border/60 text-muted-foreground/80 modern-scale-sm modern-hover hover:bg-secondary/50 hover:text-foreground hover:border-primary/50 shadow-sm reveal stagger-${index + 1}`}
              aria-label={social.name}
            >
              <svg class="h-8 w-8" fill="currentColor" viewBox="0 0 24 24">
                <path d={social.icon} />
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
