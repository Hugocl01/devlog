---
export const prerender = false;
import "@/styles/global.css";
import { ChevronsLeftRightEllipsis } from "@lucide/astro";

const { site_name } = Astro.locals.settings;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Mantenimiento · {site_name}</title>
    <script is:inline>
      const isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.classList[isDark ? "add" : "remove"]("dark");
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased font-sans flex flex-col items-center justify-center px-4">
    <div class="text-center max-w-md">
      <div class="mb-8 flex justify-center">
        <span class="flex items-center gap-2 text-2xl font-bold text-foreground">
          <ChevronsLeftRightEllipsis class="h-7 w-7" />
          {site_name}
        </span>
      </div>

      <div class="mb-6 flex justify-center">
        <div class="relative flex h-24 w-24 items-center justify-center rounded-full bg-secondary/40 border border-border">
          <svg class="h-12 w-12 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />
          </svg>
        </div>
      </div>

      <h1 class="text-3xl font-extrabold tracking-tight mb-3">En mantenimiento</h1>
      <p class="text-muted-foreground text-lg mb-8">
        Estamos realizando tareas de mantenimiento. Volvemos pronto.
      </p>

      <p class="text-xs text-muted-foreground/60">
        ¿Eres administrador?{" "}
        <a href="/auth/login" class="text-primary hover:underline underline-offset-2">Iniciar sesión</a>
      </p>
    </div>
  </body>
</html>
