---
export const prerender = false;
import BlogLayout from "@/layouts/BlogLayout.astro";
import PostCard from "@/components/blog/PostCard.astro";
import Pagination from "@/components/blog/Pagination.astro";
import { prisma } from "@/lib/prisma";

const PAGE_SIZE = 10;
const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") ?? "1", 10) || 1);

const now = new Date();
const publishedFilter = { draft: false, publishedAt: { lte: now } };

const [total, dbPosts] = await Promise.all([
  prisma.post.count({ where: publishedFilter }),
  prisma.post.findMany({
    where: publishedFilter,
    orderBy: { publishedAt: "desc" },
    skip: (page - 1) * PAGE_SIZE,
    take: PAGE_SIZE,
    select: {
      slug: true,
      title: true,
      description: true,
      publishedAt: true,
      coverImage: true,
      readingTime: true,
      tags: { select: { tag: { select: { name: true, color: true } } } },
    },
  }),
]);

const totalPages = Math.ceil(total / PAGE_SIZE);

// Redirect out-of-range pages
if (page > totalPages && totalPages > 0) return Astro.redirect("/blog");

const posts = dbPosts.map((p) => ({
  id: p.slug,
  title: p.title,
  description: p.description,
  date: p.publishedAt ?? new Date(),
  tags: p.tags.map((t) => ({ name: t.tag.name, color: t.tag.color })),
  cover: p.coverImage ?? undefined,
  readingTime: p.readingTime ?? undefined,
}));
---

<BlogLayout>
  <div class="container mx-auto max-w-6xl px-4">
    <header class="py-16 text-center md:py-20">
      <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl lg:text-6xl reveal">
        Todos los Artículos
      </h1>
      <p class="mt-4 max-w-2xl mx-auto text-lg text-muted-foreground reveal stagger-1">
        {total} publicaciones sobre desarrollo, diseño y tecnología.
        {totalPages > 1 && <span>Página {page} de {totalPages}.</span>}
      </p>
    </header>

    {total === 0 ? (
      <div class="flex flex-col items-center justify-center py-20 pb-32 text-center gap-6">
        <div class="rounded-full bg-secondary/40 border border-dashed border-border p-8">
          <svg class="h-10 w-10 text-muted-foreground/40" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-semibold mb-2">Aún no hay artículos publicados</h2>
          <p class="text-muted-foreground text-sm max-w-xs mx-auto">Vuelve pronto, el contenido está en camino.</p>
        </div>
      </div>
    ) : (
      <section class="grid grid-cols-1 gap-8 pb-4 md:grid-cols-1 lg:grid-cols-1">
        {
          posts.map((post, index) => (
            <PostCard
              id={post.id}
              title={post.title}
              description={post.description}
              date={post.date}
              tags={post.tags}
              cover={post.cover}
              readingTime={post.readingTime}
              class={`stagger-${(index % 5) + 1}`}
            />
          ))
        }
      </section>
    )}

    <Pagination currentPage={page} totalPages={totalPages} baseUrl="/blog" />
  </div>
</BlogLayout>
