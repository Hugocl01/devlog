---
export const prerender = false;
import BlogLayout from "@/layouts/BlogLayout.astro";
import PostCard from "@/components/blog/PostCard.astro";
import { prisma } from "@/lib/prisma";

const dbPosts = await prisma.post.findMany({
  where: { draft: false, publishedAt: { lte: new Date() } },
  orderBy: { publishedAt: "desc" },
  take: 3,
  select: {
    slug: true, title: true, description: true, publishedAt: true,
    coverImage: true, readingTime: true,
    tags: { select: { tag: { select: { name: true, color: true } } } },
  },
});

const featuredPosts = dbPosts.map((p) => ({
  id: p.slug, title: p.title, description: p.description,
  date: p.publishedAt ?? new Date(),
  tags: p.tags.map((t) => ({ name: t.tag.name, color: t.tag.color })),
  cover: p.coverImage ?? undefined,
  readingTime: p.readingTime ?? undefined,
}));
---

<BlogLayout
  title="DevLog"
  description="Descubre artículos sobre desarrollo web, tecnología, mejores prácticas y más. Comparto mi experiencia y aprendizaje con la comunidad."
>
  <div class="flex-1 my-6">
    <section class="container mx-auto px-4 py-20">
      <div class="flex flex-col items-center text-center">
        <h1 class="text-balance text-5xl font-bold tracking-tight md:text-6xl lg:text-7xl reveal">
          Bienvenido a DevLog
        </h1>
        <p
          class="mt-6 max-w-2xl text-balance text-lg leading-relaxed text-muted-foreground md:text-xl reveal stagger-1"
        >
          Descubre artículos sobre desarrollo web, tecnología, mejores prácticas y más. Comparto mi
          experiencia y aprendizaje con la comunidad.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4 reveal stagger-2">
          <a
            href="/blog"
            class="inline-flex h-11 items-center justify-center rounded-full bg-primary px-8 text-sm font-medium text-primary-foreground modern-hover modern-scale-sm hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
          >
            Ver todos los posts
          </a>
          <a
            href="/about"
            class="inline-flex h-11 items-center justify-center rounded-full border border-border/60 bg-secondary/30 px-8 text-sm font-medium text-muted-foreground modern-hover modern-scale-sm hover:bg-secondary/50 hover:text-foreground hover:border-primary/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          >
            Acerca de mí
          </a>
        </div>

        <a
          href="/updates"
          class="mt-6 inline-flex h-11 items-center justify-center gap-2.5 rounded-full border border-border/60 bg-secondary/30 px-8 text-sm font-medium text-muted-foreground modern-hover modern-scale-sm hover:bg-secondary/50 hover:text-foreground hover:border-primary/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring reveal stagger-3"
        >
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-60"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary shadow-[0_0_6px_var(--color-primary)]"></span>
          </span>
          Actualizaciones del proyecto
        </a>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 py-12">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          featuredPosts.map((post, index) => (
            <PostCard
              id={post.id}
              title={post.title}
              description={post.description}
              date={post.date}
              tags={post.tags}
              cover={post.cover}
              readingTime={post.readingTime}
              class={`stagger-${(index % 5) + 1}`}
            />
          ))
        }
      </div>
    </section>
  </div>
</BlogLayout>
