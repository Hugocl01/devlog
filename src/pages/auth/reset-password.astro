---
export const prerender = false;
import AuthLayout from "@/layouts/AuthLayout.astro";
import { Lock, Eye, EyeOff, ArrowLeft } from "@lucide/astro";
---

<AuthLayout
  title="Nueva contraseña"
  description="Establece una nueva contraseña para tu cuenta de DevLog."
>
  <div class="w-full max-w-md reveal">
    <!-- Card -->
    <div class="bg-card border border-border/60 rounded-2xl shadow-sm p-8">

      <!-- Header -->
      <div class="flex flex-col items-center text-center mb-8">
        <div class="flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 border border-primary/20 mb-4">
          <Lock class="h-6 w-6 text-primary" />
        </div>
        <h1 class="text-2xl font-bold tracking-tight">Nueva contraseña</h1>
        <p class="mt-1.5 text-sm text-muted-foreground max-w-xs">
          Elige una contraseña segura para proteger tu cuenta
        </p>
      </div>

      <!-- Form -->
      <form class="space-y-5" novalidate>

        <!-- New password -->
        <div class="space-y-1.5">
          <label for="password" class="text-sm font-medium">Nueva contraseña</label>
          <div class="relative">
            <input
              id="password"
              name="password"
              type="password"
              autocomplete="new-password"
              placeholder="Mínimo 8 caracteres"
              required
              class="dark:bg-input/30 border-input h-10 w-full rounded-md border bg-transparent px-3 py-1 pr-10 text-sm shadow-xs transition-[color,box-shadow] outline-none placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px]"
            />
            <button
              type="button"
              id="toggle-password"
              aria-label="Mostrar u ocultar contraseña"
              class="absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground transition-colors duration-200"
            >
              <Eye id="icon-show" class="h-4 w-4" />
              <EyeOff id="icon-hide" class="h-4 w-4 hidden" />
            </button>
          </div>

          <!-- Strength indicator -->
          <div class="space-y-1.5 pt-1">
            <div class="flex gap-1">
              <div class="h-1 flex-1 rounded-full bg-border transition-colors duration-300" data-bar="1"></div>
              <div class="h-1 flex-1 rounded-full bg-border transition-colors duration-300" data-bar="2"></div>
              <div class="h-1 flex-1 rounded-full bg-border transition-colors duration-300" data-bar="3"></div>
              <div class="h-1 flex-1 rounded-full bg-border transition-colors duration-300" data-bar="4"></div>
            </div>
            <p id="strength-label" class="text-xs text-muted-foreground hidden"></p>
          </div>
        </div>

        <!-- Confirm new password -->
        <div class="space-y-1.5">
          <label for="confirm-password" class="text-sm font-medium">Confirmar nueva contraseña</label>
          <div class="relative">
            <input
              id="confirm-password"
              name="confirm-password"
              type="password"
              autocomplete="new-password"
              placeholder="Repite tu nueva contraseña"
              required
              class="dark:bg-input/30 border-input h-10 w-full rounded-md border bg-transparent px-3 py-1 pr-10 text-sm shadow-xs transition-[color,box-shadow] outline-none placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px]"
            />
            <button
              type="button"
              id="toggle-confirm"
              aria-label="Mostrar u ocultar confirmación"
              class="absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground transition-colors duration-200"
            >
              <Eye id="icon-show-confirm" class="h-4 w-4" />
              <EyeOff id="icon-hide-confirm" class="h-4 w-4 hidden" />
            </button>
          </div>
          <p id="match-error" class="text-xs text-destructive hidden">Las contraseñas no coinciden</p>
        </div>

        <!-- Requirements list -->
        <ul class="space-y-1.5 text-xs text-muted-foreground" id="requirements">
          <li class="flex items-center gap-2" data-req="length">
            <span class="flex h-3.5 w-3.5 items-center justify-center rounded-full border border-border text-[9px]">✓</span>
            Mínimo 8 caracteres
          </li>
          <li class="flex items-center gap-2" data-req="uppercase">
            <span class="flex h-3.5 w-3.5 items-center justify-center rounded-full border border-border text-[9px]">✓</span>
            Al menos una mayúscula
          </li>
          <li class="flex items-center gap-2" data-req="number">
            <span class="flex h-3.5 w-3.5 items-center justify-center rounded-full border border-border text-[9px]">✓</span>
            Al menos un número
          </li>
        </ul>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full h-11 inline-flex items-center justify-center gap-2 rounded-full bg-primary text-primary-foreground text-sm font-medium modern-hover modern-scale-sm hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 transition-all"
        >
          <Lock class="h-4 w-4" />
          Guardar nueva contraseña
        </button>
      </form>

      <!-- Back -->
      <div class="mt-6 flex justify-center">
        <a
          href="/auth/login"
          class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors duration-200"
        >
          <ArrowLeft class="h-3.5 w-3.5" />
          Volver al inicio de sesión
        </a>
      </div>
    </div>
  </div>
</AuthLayout>

<script>
  const strengthLevels = [
    { label: "Muy débil", colors: ["bg-destructive", "bg-border", "bg-border", "bg-border"] },
    { label: "Débil", colors: ["bg-orange-500", "bg-orange-500", "bg-border", "bg-border"] },
    { label: "Aceptable", colors: ["bg-yellow-500", "bg-yellow-500", "bg-yellow-500", "bg-border"] },
    { label: "Fuerte", colors: ["bg-green-500", "bg-green-500", "bg-green-500", "bg-green-500"] },
  ];

  const getStrength = (pwd: string): number => {
    if (pwd.length === 0) return -1;
    let score = 0;
    if (pwd.length >= 8) score++;
    if (pwd.length >= 12) score++;
    if (/[A-Z]/.test(pwd) && /[a-z]/.test(pwd)) score++;
    if (/[0-9]/.test(pwd) && /[^A-Za-z0-9]/.test(pwd)) score++;
    return Math.min(score, 3);
  };

  const reqItems = {
    length: (p: string) => p.length >= 8,
    uppercase: (p: string) => /[A-Z]/.test(p),
    number: (p: string) => /[0-9]/.test(p),
  };

  document.addEventListener("astro:page-load", () => {
    // Show/hide toggles
    const makeToggle = (btnId: string, inputId: string, showId: string, hideId: string) => {
      const btn = document.getElementById(btnId);
      const input = document.getElementById(inputId) as HTMLInputElement;
      const show = document.getElementById(showId);
      const hide = document.getElementById(hideId);
      btn?.addEventListener("click", () => {
        const isPass = input.type === "password";
        input.type = isPass ? "text" : "password";
        show?.classList.toggle("hidden", isPass);
        hide?.classList.toggle("hidden", !isPass);
      });
    };

    makeToggle("toggle-password", "password", "icon-show", "icon-hide");
    makeToggle("toggle-confirm", "confirm-password", "icon-show-confirm", "icon-hide-confirm");

    // Password strength
    const passwordInput = document.getElementById("password") as HTMLInputElement;
    const bars = document.querySelectorAll("[data-bar]");
    const strengthLabel = document.getElementById("strength-label");

    passwordInput?.addEventListener("input", () => {
      const val = passwordInput.value;

      const strength = getStrength(val);
      if (strength === -1) {
        bars.forEach(b => b.className = "h-1 flex-1 rounded-full bg-border transition-colors duration-300");
        if (strengthLabel) strengthLabel.classList.add("hidden");
      } else {
        const level = strengthLevels[strength];
        bars.forEach((b, i) => {
          b.className = `h-1 flex-1 rounded-full transition-colors duration-300 ${level.colors[i]}`;
        });
        if (strengthLabel) {
          strengthLabel.textContent = level.label;
          strengthLabel.classList.remove("hidden");
        }
      }

      Object.entries(reqItems).forEach(([key, check]) => {
        const el = document.querySelector(`[data-req="${key}"]`);
        const icon = el?.querySelector("span");
        if (!el || !icon) return;
        const met = check(val);
        icon.className = `flex h-3.5 w-3.5 items-center justify-center rounded-full text-[9px] transition-colors duration-200 ${
          met ? "bg-green-500/20 border-green-500 text-green-600 border" : "border border-border"
        }`;
      });
    });

    // Confirm match
    const confirmInput = document.getElementById("confirm-password") as HTMLInputElement;
    const matchError = document.getElementById("match-error");
    confirmInput?.addEventListener("input", () => {
      const mismatch = confirmInput.value.length > 0 && confirmInput.value !== passwordInput.value;
      matchError?.classList.toggle("hidden", !mismatch);
    });

    // Form submission
    const token = new URLSearchParams(window.location.search).get("token");
    const form = document.querySelector("form") as HTMLFormElement;
    if (!form) return;

    const submitBtn = form.querySelector("button[type=submit]") as HTMLButtonElement;

    const errorBox = document.createElement("p");
    errorBox.className = "text-sm text-destructive text-center hidden";
    form.prepend(errorBox);

    if (!token) {
      errorBox.textContent = "Enlace inválido. Solicita uno nuevo desde la página de recuperación.";
      errorBox.classList.remove("hidden");
      submitBtn.disabled = true;
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const password = passwordInput.value;
      const confirm = confirmInput.value;

      if (password !== confirm) {
        errorBox.textContent = "Las contraseñas no coinciden";
        errorBox.classList.remove("hidden");
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = "Guardando...";
      errorBox.classList.add("hidden");

      try {
        const res = await fetch("/api/auth/reset-password", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token, password }),
        });

        const data = await res.json();

        if (!res.ok) {
          errorBox.textContent = data.error ?? "Error al restablecer la contraseña";
          errorBox.classList.remove("hidden");
          return;
        }

        window.location.href = "/auth/login?reset=success";
      } catch {
        errorBox.textContent = "Error de conexión. Inténtalo de nuevo.";
        errorBox.classList.remove("hidden");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Guardar nueva contraseña";
      }
    });
  });
</script>
