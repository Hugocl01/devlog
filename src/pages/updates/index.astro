---
export const prerender = false;
import BlogLayout from "@/layouts/BlogLayout.astro";
import UpdateCard from "@/components/blog/UpdateCard.astro";
import Pagination from "@/components/blog/Pagination.astro";
import { prisma } from "@/lib/prisma";

const PAGE_SIZE = 10;
const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") ?? "1", 10) || 1);

const publishedFilter = { draft: false, publishedAt: { lte: new Date() } };

const [total, dbUpdates] = await Promise.all([
  prisma.update.count({ where: publishedFilter }),
  prisma.update.findMany({
    where: publishedFilter,
    orderBy: { publishedAt: "desc" },
    skip: (page - 1) * PAGE_SIZE,
    take: PAGE_SIZE,
    select: {
      slug: true,
      title: true,
      description: true,
      author: { select: { name: true } },
      publishedAt: true,
      readingTime: true,
      type: { select: { name: true } },
    },
  }),
]);

const totalPages = Math.ceil(total / PAGE_SIZE);

if (page > totalPages && totalPages > 0) return Astro.redirect("/updates");

const updates = dbUpdates.map((u) => ({
  id: u.slug,
  title: u.title,
  description: u.description,
  date: u.publishedAt ?? new Date(),
  author: u.author?.name ?? undefined,
  type: u.type.name as "feature" | "bugfix" | "improvement" | "general",
  readingTime: u.readingTime ?? undefined,
}));
---

<BlogLayout
  title="Actualizaciones"
  description="Historial de cambios de DevLog: nuevas funcionalidades, mejoras y correcciones ordenadas cronológicamente."
>
  <div class="container mx-auto max-w-6xl px-4">
    <header class="py-16 text-center md:py-20">
      <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl lg:text-6xl reveal">
        Actualizaciones del Blog
      </h1>
      <p class="mt-4 max-w-2xl mx-auto text-lg text-muted-foreground reveal stagger-1">
        Mantente informado sobre las nuevas características, mejoras y correcciones de DevLog.
        {totalPages > 1 && <span>Página {page} de {totalPages}.</span>}
      </p>
    </header>

    <section class="grid grid-cols-1 gap-8 pb-4 md:grid-cols-1 lg:grid-cols-1">
      {
        updates.map((u, index) => (
          <UpdateCard
            id={u.id}
            title={u.title}
            description={u.description}
            date={u.date}
            type={u.type}
            author={u.author}
            readingTime={u.readingTime}
            class={`stagger-${(index % 5) + 1}`}
          />
        ))
      }
    </section>

    <Pagination currentPage={page} totalPages={totalPages} baseUrl="/updates" />
  </div>
</BlogLayout>
