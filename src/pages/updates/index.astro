---
import { getCollection } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
import UpdateCard from "@/components/blog/UpdateCard.astro";
import { calculateReadingTime } from "@/utils/readingTime";

const updates = (await getCollection("updates"))
  .filter((update) => !update.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BlogLayout>
  <div class="container mx-auto max-w-6xl px-4">
    <header class="py-16 text-center md:py-20">
      <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl lg:text-6xl reveal">
        Actualizaciones del Blog
      </h1>
      <p class="mt-4 max-w-2xl mx-auto text-lg text-muted-foreground reveal stagger-1">
        Mantente informado sobre las nuevas características, mejoras y correcciones de DevLog.
      </p>
    </header>

    <section class="grid grid-cols-1 gap-8 pb-20 md:grid-cols-1 lg:grid-cols-1">
      {
        updates.map(({ id, data, body }, index) => (
          <UpdateCard
            id={id}
            title={data.title}
            description={data.description}
            date={data.date}
            type={data.type}
            author={data.author}
            readingTime={body ? calculateReadingTime(body) : undefined}
            class={`stagger-${(index % 5) + 1}`}
          />
        ))
      }
    </section>
  </div>
</BlogLayout>

