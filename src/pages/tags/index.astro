---
export const prerender = false;
import BlogLayout from "@/layouts/BlogLayout.astro";
import TagSearch from "@/components/tags/TagSearch";
import { prisma } from "@/lib/prisma";

const tagRows = await prisma.tag.findMany({
  where: { posts: { some: { post: { draft: false, publishedAt: { lte: new Date() } } } } },
  select: {
    name: true,
    _count: { select: { posts: true } },
  },
  orderBy: { name: "asc" },
});

const tags: [string, number][] = tagRows.map((t) => [t.name, t._count.posts]);
---

<BlogLayout
  title="Etiquetas"
  description="Explora todos los temas del blog por etiqueta y encuentra artículos sobre desarrollo web, tecnología, proyectos y más."
>
  <div class="container mx-auto max-w-6xl px-4">
    <header class="py-16 text-center md:py-20">
      <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl lg:text-6xl reveal">
        Todas las Etiquetas
      </h1>
      <p class="mt-4 max-w-2xl mx-auto text-lg text-muted-foreground reveal stagger-1">
        Explora {tags.length} etiquetas y navega por todos los temas del blog para descubrir
        contenido relacionado.
      </p>
    </header>

    <section class="max-w-4xl mx-auto pb-20">
      <TagSearch client:load tags={tags} />
    </section>
  </div>
</BlogLayout>
