---
export const prerender = false;
import AdminLayout from "@/layouts/AdminLayout.astro";
import PostEditor, { type PostEditorData } from "@/components/admin/PostEditor";
import { prisma } from "@/lib/prisma";

const { slug } = Astro.params;

const [post, adminRole] = await Promise.all([
  prisma.post.findUnique({
    where: { slug },
    select: {
      slug: true,
      title: true,
      description: true,
      content: true,
      authorId: true,
      draft: true,
      coverImage: true,
      publishedAt: true,
      metaTitle: true,
      canonical: true,
      tags: { select: { tag: { select: { name: true } } } },
    },
  }),
  prisma.role.findFirst({ where: { name: "ADMIN" } }),
]);

if (!post) return Astro.redirect("/admin/posts");

const users = adminRole
  ? await prisma.user.findMany({
      where: { roleId: adminRole.id },
      select: { id: true, name: true },
      orderBy: { name: "asc" },
    })
  : [];

const initialData: PostEditorData = {
  slug: post.slug,
  title: post.title,
  description: post.description,
  content: post.content,
  authorId: post.authorId ?? undefined,
  tags: post.tags.map((t) => t.tag.name),
  draft: post.draft,
  coverImage: post.coverImage ?? undefined,
  scheduledAt: post.publishedAt && post.publishedAt > new Date()
    ? post.publishedAt.toISOString()
    : undefined,
  metaTitle: post.metaTitle ?? undefined,
  canonical: post.canonical ?? undefined,
};
---

<AdminLayout title={`Editar: ${post.title}`}>
  <PostEditor mode="edit" initialData={JSON.parse(JSON.stringify(initialData))} users={users} client:load />
</AdminLayout>
