---
export const prerender = false;
import AdminLayout from "@/layouts/AdminLayout.astro";
import ReactionDetailView from "@/components/admin/ReactionDetailView";
import { prisma } from "@/lib/prisma";

const { id } = Astro.params;
if (!id || isNaN(Number(id))) return Astro.redirect("/admin/reaction-types");

const type = await prisma.reactionType.findUnique({
  where: { id: Number(id) },
  select: {
    id: true,
    name: true,
    emoji: true,
    label: true,
    reactions: {
      orderBy: { createdAt: "desc" },
      select: {
        id: true,
        createdAt: true,
        user: { select: { id: true, name: true, avatar: true } },
        post: { select: { slug: true, title: true } },
      },
    },
  },
});

if (!type) return Astro.redirect("/admin/reaction-types");
---

<AdminLayout title={`Reacción: ${type.label}`}>
  <ReactionDetailView type={JSON.parse(JSON.stringify(type))} client:load />
</AdminLayout>
