---
export const prerender = false;
import AdminLayout from "@/layouts/AdminLayout.astro";
import { prisma } from "@/lib/prisma";
import { TrendingUp, TrendingDown, Minus, ShieldCheck, TriangleAlert, FilePlus, Zap, MessageSquare as MsgIcon, Users as UsersIcon, Image, ChartBar } from "@lucide/astro";
import DashboardCharts from "@/components/admin/DashboardCharts";
import DashboardStats from "@/components/admin/DashboardStats";

const weekAgo      = new Date(Date.now() - 7  * 24 * 60 * 60 * 1000);
const twoWeeksAgo  = new Date(Date.now() - 14 * 24 * 60 * 60 * 1000);
const eightWeeksAgo = new Date(Date.now() - 8 * 7 * 24 * 60 * 60 * 1000);

const [
  userCount,
  verifiedCount,
  commentCount,
  reactionCount,
  newUsersThisWeek,
  newUsersLastWeek,
  newCommentsThisWeek,
  newCommentsLastWeek,
  newReactionsThisWeek,
  newReactionsLastWeek,
  newPostsThisWeek,
  newPostsLastWeek,
  reactionsByType,
  reactionTypes,
  recentUsers,
  recentComments,
  topCommentGroups,
  topReactionGroups,
  topCommenterGroups,
  posts,
  usersForChart,
  commentsForChart,
  recentAuditLogs,
  topViewedPosts,
  postDraftCount,
  postScheduledCount,
  updateDraftCount,
  updateScheduledCount,
  bannedCommentsCount,
  bannedUsersCount,
  unverifiedOldUsers,
  staleDraftPosts,
] = await Promise.all([
  prisma.user.count(),
  prisma.user.count({ where: { emailVerified: true } }),
  prisma.comment.count({ where: { deleted: false } }),
  prisma.reaction.count(),
  prisma.user.count({ where: { createdAt: { gte: weekAgo } } }),
  prisma.user.count({ where: { createdAt: { gte: twoWeeksAgo, lt: weekAgo } } }),
  prisma.comment.count({ where: { deleted: false, createdAt: { gte: weekAgo } } }),
  prisma.comment.count({ where: { deleted: false, createdAt: { gte: twoWeeksAgo, lt: weekAgo } } }),
  prisma.reaction.count({ where: { createdAt: { gte: weekAgo } } }),
  prisma.reaction.count({ where: { createdAt: { gte: twoWeeksAgo, lt: weekAgo } } }),
  prisma.post.count({ where: { draft: false, publishedAt: { gte: weekAgo } } }),
  prisma.post.count({ where: { draft: false, publishedAt: { gte: twoWeeksAgo, lt: weekAgo } } }),
  prisma.reaction.groupBy({ by: ["typeId"], _count: { id: true }, orderBy: { _count: { id: "desc" } } }),
  prisma.reactionType.findMany({ select: { id: true, emoji: true, label: true }, orderBy: { id: "asc" } }),
  prisma.user.findMany({
    orderBy: { createdAt: "desc" }, take: 5,
    select: { id: true, name: true, email: true, avatar: true, createdAt: true, role: { select: { name: true } } },
  }),
  prisma.comment.findMany({
    where: { deleted: false }, orderBy: { createdAt: "desc" }, take: 5,
    select: { id: true, content: true, createdAt: true, post: { select: { slug: true } }, user: { select: { name: true } } },
  }),
  prisma.comment.groupBy({ by: ["postId"], where: { deleted: false }, _count: { id: true }, orderBy: { _count: { id: "desc" } }, take: 5 }),
  prisma.reaction.groupBy({ by: ["postId"], _count: { id: true }, orderBy: { _count: { id: "desc" } }, take: 5 }),
  prisma.comment.groupBy({ by: ["userId"], where: { deleted: false }, _count: { id: true }, orderBy: { _count: { id: "desc" } }, take: 5 }),
  prisma.post.findMany({
    where: { draft: false },
    orderBy: { publishedAt: "asc" },
    select: { id: true, slug: true, title: true, publishedAt: true },
  }),
  // Chart raw data
  prisma.user.findMany({ where: { createdAt: { gte: eightWeeksAgo } }, select: { createdAt: true } }),
  prisma.comment.findMany({ where: { deleted: false, createdAt: { gte: eightWeeksAgo } }, select: { createdAt: true } }),
  prisma.auditLog.findMany({ orderBy: { createdAt: "desc" }, take: 15, select: { id: true, action: true, entity: true, entityId: true, userEmail: true, createdAt: true } }),
  // Top posts by views
  prisma.post.findMany({
    where: { draft: false },
    orderBy: { views: { _count: "desc" } },
    take: 5,
    select: { slug: true, title: true, _count: { select: { views: true } } },
  }),
  // Content pipeline
  prisma.post.count({ where: { draft: true } }),
  prisma.post.count({ where: { draft: false, publishedAt: { gt: new Date() } } }),
  prisma.update.count({ where: { draft: true } }),
  prisma.update.count({ where: { draft: false, publishedAt: { gt: new Date() } } }),
  // Alerts
  prisma.comment.count({ where: { deleted: false, banned: true } }),
  prisma.user.count({ where: { banned: true } }),
  prisma.user.count({ where: { emailVerified: false, createdAt: { lt: new Date(Date.now() - 24 * 60 * 60 * 1000) } } }),
  prisma.post.findMany({ where: { draft: true, updatedAt: { lt: new Date(Date.now() - 30 * 24 * 60 * 60 * 1000) } }, select: { slug: true, title: true, updatedAt: true }, take: 3, orderBy: { updatedAt: "asc" } }),
]);

// Resolve post slugs & titles for top content sections
const allPostIds = [...new Set([
  ...topCommentGroups.map(g => g.postId),
  ...topReactionGroups.map(g => g.postId),
])];

const [topPostsDb, topCommentersDb] = await Promise.all([
  allPostIds.length > 0
    ? prisma.post.findMany({ where: { id: { in: allPostIds } }, select: { id: true, slug: true } })
    : [],
  topCommenterGroups.length > 0
    ? prisma.user.findMany({
        where: { id: { in: topCommenterGroups.map(g => g.userId) } },
        select: { id: true, name: true, avatar: true },
      })
    : [],
]);

const postSlugById   = new Map(topPostsDb.map(p => [p.id, p.slug]));
const titleBySlug    = new Map(posts.map(p => [p.slug, p.title]));
const userById       = new Map(topCommentersDb.map(u => [u.id, u]));

const topCommentedPosts = topCommentGroups.map(g => {
  const slug  = postSlugById.get(g.postId) ?? String(g.postId);
  return { slug, count: g._count.id, title: titleBySlug.get(slug) ?? slug };
});

const topReactedPosts = topReactionGroups.map(g => {
  const slug  = postSlugById.get(g.postId) ?? String(g.postId);
  return { slug, count: g._count.id, title: titleBySlug.get(slug) ?? slug };
});

const topCommenters = topCommenterGroups
  .map(g => ({ count: g._count.id, ...userById.get(g.userId)! }))
  .filter(u => u.id);

// Reactions breakdown — include all types, zero if no reactions yet
const reactionCountById = new Map(reactionsByType.map(r => [r.typeId, r._count.id]));
const reactionsBreakdown = reactionTypes.map(t => ({ ...t, count: reactionCountById.get(t.id) ?? 0 }));
const totalReactionCount = reactionsBreakdown.reduce((s, r) => s + r.count, 0);

// ── Chart data ──────────────────────────────────────────────────────────────

// Get the ISO date of the Monday for any given date
function mondayOf(d: Date): string {
  const copy = new Date(d);
  const day = copy.getUTCDay();
  const diff = day === 0 ? -6 : 1 - day;
  copy.setUTCDate(copy.getUTCDate() + diff);
  return copy.toISOString().slice(0, 10);
}

// Build 8 weekly buckets (Mon → Sun), oldest first
const activityData: { label: string; usuarios: number; comentarios: number }[] = [];
for (let i = 7; i >= 0; i--) {
  const ref = new Date(Date.now() - i * 7 * 24 * 60 * 60 * 1000);
  const key = mondayOf(ref);
  const date = new Date(key + "T00:00:00Z");
  const label = date.toLocaleDateString("es-ES", { day: "numeric", month: "short", timeZone: "UTC" });
  activityData.push({ label, usuarios: 0, comentarios: 0 });
}

// Map each record to its bucket index
function bucketIndex(createdAt: Date): number {
  const key = mondayOf(createdAt);
  const monday = new Date(key + "T00:00:00Z");
  const msBetween = Date.now() - monday.getTime();
  const weeksAgo  = Math.floor(msBetween / (7 * 24 * 60 * 60 * 1000));
  const idx = 7 - weeksAgo;
  return idx >= 0 && idx <= 7 ? idx : -1;
}

for (const u of usersForChart) {
  const i = bucketIndex(u.createdAt);
  if (i >= 0) activityData[i].usuarios++;
}
for (const c of commentsForChart) {
  const i = bucketIndex(c.createdAt);
  if (i >= 0) activityData[i].comentarios++;
}

// Build 12 monthly buckets for published posts
const postsData: { label: string; posts: number }[] = [];
for (let i = 11; i >= 0; i--) {
  const d = new Date();
  d.setDate(1);
  d.setMonth(d.getMonth() - i);
  const key   = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  const label = d.toLocaleDateString("es-ES", { month: "short" });
  postsData.push({ label, posts: 0, _key: key } as any);
}
for (const post of posts) {
  if (!post.publishedAt) continue;
  const d   = new Date(post.publishedAt);
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`;
  const bucket = (postsData as any[]).find((b: any) => b._key === key);
  if (bucket) bucket.posts++;
}
// Clean internal key before passing to component
const postsChartData = postsData.map(({ label, posts }) => ({ label, posts }));

// ── Helpers ──────────────────────────────────────────────────────────────────
const publishedCount = posts.length;
const verificationRate = userCount > 0 ? Math.round((verifiedCount / userCount) * 100) : 0;

function delta(current: number, previous: number) {
  return current - previous;
}

function pct(current: number, previous: number): { value: number; label: string } | null {
  if (previous === 0) return current > 0 ? { value: 100, label: "+100%" } : null;
  const v = Math.round(((current - previous) / previous) * 100);
  return { value: v, label: v > 0 ? `+${v}%` : `${v}%` };
}

function formatDate(date: string | Date) {
  return new Date(date).toLocaleDateString("es-ES", { day: "numeric", month: "short", year: "numeric" });
}

function getInitials(name: string) {
  return name.split(" ").map((n: string) => n[0]).slice(0, 2).join("").toUpperCase();
}

function actionColor(action: string): string {
  const map: { [k: string]: string } = {
    CREATE:    "bg-green-500/10 text-green-600 dark:text-green-400",
    UPDATE:    "bg-blue-500/10 text-blue-600 dark:text-blue-400",
    DELETE:    "bg-red-500/10 text-red-600 dark:text-red-400",
    PUBLISH:   "bg-primary/10 text-primary",
    UNPUBLISH: "bg-amber-500/10 text-amber-600 dark:text-amber-400",
    BAN:       "bg-orange-500/10 text-orange-600 dark:text-orange-400",
    UNBAN:     "bg-teal-500/10 text-teal-600 dark:text-teal-400",
  };
  return map[action] ?? "bg-secondary/50 text-muted-foreground";
}

const userDelta    = delta(newUsersThisWeek, newUsersLastWeek);
const commentDelta = delta(newCommentsThisWeek, newCommentsLastWeek);

// ── Alerts ────────────────────────────────────────────────────────────────────
const alerts: { level: "warn" | "info"; message: string; href: string }[] = [];
if (bannedCommentsCount > 0)
  alerts.push({ level: "warn", message: `${bannedCommentsCount} comentario${bannedCommentsCount !== 1 ? "s" : ""} baneado${bannedCommentsCount !== 1 ? "s" : ""} pendiente${bannedCommentsCount !== 1 ? "s" : ""} de revisión`, href: "/admin/comments/banned" });
if (bannedUsersCount > 0)
  alerts.push({ level: "warn", message: `${bannedUsersCount} usuario${bannedUsersCount !== 1 ? "s" : ""} con acceso suspendido`, href: "/admin/users/banned" });
if (unverifiedOldUsers > 0)
  alerts.push({ level: "info", message: `${unverifiedOldUsers} usuario${unverifiedOldUsers !== 1 ? "s" : ""} sin verificar email (más de 24 h)`, href: "/admin/users" });
if (staleDraftPosts.length > 0)
  alerts.push({ level: "info", message: `${staleDraftPosts.length} borrador${staleDraftPosts.length !== 1 ? "es" : ""} sin actualizar en más de 30 días`, href: "/admin/posts?filter=draft" });

const initialStats = [
  { key: "posts",     label: "Posts publicados", value: publishedCount, trend: pct(newPostsThisWeek,     newPostsLastWeek)     },
  { key: "users",     label: "Usuarios",          value: userCount,      trend: pct(newUsersThisWeek,     newUsersLastWeek)     },
  { key: "comments",  label: "Comentarios",       value: commentCount,   trend: pct(newCommentsThisWeek,  newCommentsLastWeek)  },
  { key: "reactions", label: "Reacciones",        value: reactionCount,  trend: pct(newReactionsThisWeek, newReactionsLastWeek) },
];
---

<AdminLayout title="Dashboard">

  <!-- ── Quick actions ────────────────────────────────────── -->
  <div class="flex flex-wrap gap-2 mb-6">
    <a href="/admin/posts/new" class="inline-flex items-center gap-1.5 rounded-full bg-primary px-3 py-2 text-xs font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
      <FilePlus class="h-3.5 w-3.5" /> Nuevo post
    </a>
    <a href="/admin/updates/new" class="inline-flex items-center gap-1.5 rounded-full border border-border/60 bg-secondary/30 px-3 py-2 text-xs font-medium text-muted-foreground hover:text-foreground hover:bg-secondary/60 transition-colors">
      <Zap class="h-3.5 w-3.5" /> Nuevo update
    </a>
    <a href="/admin/comments" class="inline-flex items-center gap-1.5 rounded-full border border-border/60 bg-secondary/30 px-3 py-2 text-xs font-medium text-muted-foreground hover:text-foreground hover:bg-secondary/60 transition-colors">
      <MsgIcon class="h-3.5 w-3.5" /> Comentarios
    </a>
    <a href="/admin/users" class="inline-flex items-center gap-1.5 rounded-full border border-border/60 bg-secondary/30 px-3 py-2 text-xs font-medium text-muted-foreground hover:text-foreground hover:bg-secondary/60 transition-colors">
      <UsersIcon class="h-3.5 w-3.5" /> Usuarios
    </a>
    <a href="/admin/media" class="inline-flex items-center gap-1.5 rounded-full border border-border/60 bg-secondary/30 px-3 py-2 text-xs font-medium text-muted-foreground hover:text-foreground hover:bg-secondary/60 transition-colors">
      <Image class="h-3.5 w-3.5" /> Medios
    </a>
    <a href="/admin/audit" class="ml-auto inline-flex items-center gap-1.5 rounded-full border border-border/60 bg-secondary/30 px-3 py-2 text-xs font-medium text-muted-foreground hover:text-foreground hover:bg-secondary/60 transition-colors">
      <ChartBar class="h-3.5 w-3.5" /> Auditoría
    </a>
  </div>

  <!-- ── Alertas ───────────────────────────────────────────── -->
  {alerts.length > 0 && (
    <div class="flex flex-col gap-2 mb-6">
      {alerts.map(alert => (
        <a
          href={alert.href}
          class={`flex items-center gap-3 rounded-xl border px-4 py-2.5 text-sm transition-colors ${
            alert.level === "warn"
              ? "border-amber-500/30 bg-amber-500/5 text-amber-700 dark:text-amber-400 hover:bg-amber-500/10"
              : "border-blue-500/20 bg-blue-500/5 text-blue-700 dark:text-blue-400 hover:bg-blue-500/10"
          }`}
        >
          <TriangleAlert class="h-4 w-4 shrink-0" />
          <span class="flex-1">{alert.message}</span>
          <span class="text-xs opacity-60">Ver →</span>
        </a>
      ))}
    </div>
  )}

  <!-- ── Row 1: Main stats (auto-refresh cada 60 s) ─────── -->
  <DashboardStats initialStats={initialStats} client:load />

  <!-- ── Row 2: Charts ─────────────────────────────────── -->
  <DashboardCharts
    activityData={activityData}
    postsData={postsChartData}
    client:load
  />

  <!-- ── Row 3: Secondary stats ────────────────────────── -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">

    <!-- Weekly activity -->
    <div class="bg-card border border-border/60 rounded-xl p-5">
      <p class="text-sm font-semibold mb-4">Actividad esta semana</p>
      <div class="flex flex-col gap-3">
        {[
          { label: "Nuevos usuarios",    value: newUsersThisWeek,    d: userDelta    },
          { label: "Nuevos comentarios", value: newCommentsThisWeek, d: commentDelta },
        ].map(({ label, value, d }) => (
          <div class="flex items-center justify-between">
            <span class="text-sm text-muted-foreground">{label}</span>
            <div class="flex items-center gap-2">
              <span class="text-lg font-bold tabular-nums">{value}</span>
              {d > 0 ? (
                <span class="inline-flex items-center gap-0.5 text-xs font-medium text-emerald-500">
                  <TrendingUp class="h-3.5 w-3.5" />+{d}
                </span>
              ) : d < 0 ? (
                <span class="inline-flex items-center gap-0.5 text-xs font-medium text-red-500">
                  <TrendingDown class="h-3.5 w-3.5" />{d}
                </span>
              ) : (
                <span class="inline-flex items-center gap-0.5 text-xs text-muted-foreground/60">
                  <Minus class="h-3 w-3" />
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
      <p class="text-xs text-muted-foreground/50 mt-4">vs. los 7 días anteriores</p>
    </div>

    <!-- Email verification -->
    <div class="bg-card border border-border/60 rounded-xl p-5">
      <div class="flex items-center gap-2 mb-4">
        <ShieldCheck class="h-4 w-4 text-primary/70" />
        <p class="text-sm font-semibold">Verificación de email</p>
      </div>
      <div class="flex items-end gap-2 mb-3">
        <span class="text-3xl font-bold tabular-nums">{verificationRate}%</span>
        <span class="text-sm text-muted-foreground mb-0.5">{verifiedCount} de {userCount}</span>
      </div>
      <div class="h-2 w-full rounded-full bg-secondary/50 overflow-hidden">
        <div
          class="h-full rounded-full bg-primary transition-all"
          style={`width: ${verificationRate}%`}
        />
      </div>
      <p class="text-xs text-muted-foreground/60 mt-2">
        {userCount - verifiedCount} {userCount - verifiedCount === 1 ? "usuario pendiente" : "usuarios pendientes"}
      </p>
    </div>

    <!-- Reactions breakdown -->
    <div class="bg-card border border-border/60 rounded-xl p-5 sm:col-span-2 lg:col-span-1">
      <p class="text-sm font-semibold mb-4">Reacciones por tipo</p>
      {totalReactionCount === 0 ? (
        <p class="text-sm text-muted-foreground/60 text-center py-4">Sin reacciones todavía.</p>
      ) : (
        <div class="flex flex-col gap-2.5">
          {reactionsBreakdown.map(r => {
            const pct = totalReactionCount > 0 ? Math.round((r.count / totalReactionCount) * 100) : 0;
            return (
              <div class="flex items-center gap-3">
                <span class="text-xl leading-none w-6 text-center shrink-0">{r.emoji}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs text-muted-foreground">{r.label}</span>
                    <span class="text-xs font-semibold tabular-nums">{r.count}</span>
                  </div>
                  <div class="h-1.5 w-full rounded-full bg-secondary/50 overflow-hidden">
                    <div class="h-full rounded-full bg-primary/60" style={`width: ${pct}%`} />
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>


    <!-- Content pipeline -->
    <div class="bg-card border border-border/60 rounded-xl p-5 sm:col-span-2 lg:col-span-1">
      <p class="text-sm font-semibold mb-4">Pipeline de contenido</p>
      <div class="space-y-3">
        {([
          { label: "Posts",   scheduled: postScheduledCount,   drafts: postDraftCount,   href: "/admin/posts"   },
          { label: "Updates", scheduled: updateScheduledCount, drafts: updateDraftCount, href: "/admin/updates" },
        ] as { label: string; scheduled: number; drafts: number; href: string }[]).map(row => (
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-xs font-medium text-muted-foreground">{row.label}</span>
              <a href={row.href} class="text-[10px] text-primary hover:underline">Ver →</a>
            </div>
            <div class="flex gap-1.5 flex-wrap">
              {row.scheduled > 0 && (
                <span class="rounded-full bg-blue-500/10 border border-blue-500/20 px-2 py-0.5 text-[11px] font-medium text-blue-600 dark:text-blue-400">
                  {row.scheduled} programado{row.scheduled !== 1 ? "s" : ""}
                </span>
              )}
              {row.drafts > 0 && (
                <span class="rounded-full bg-amber-500/10 border border-amber-500/20 px-2 py-0.5 text-[11px] font-medium text-amber-600 dark:text-amber-400">
                  {row.drafts} borrador{row.drafts !== 1 ? "es" : ""}
                </span>
              )}
              {row.drafts === 0 && row.scheduled === 0 && (
                <span class="text-xs text-muted-foreground/50">Todo publicado ✓</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── Row 3: Top content ─────────────────────────────── -->
  <div class="grid sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-6">

    <!-- Top commented posts -->
    <div class="bg-card border border-border/60 rounded-xl p-5">
      <p class="text-sm font-semibold mb-4">Posts más comentados</p>
      {topCommentedPosts.length === 0 ? (
        <p class="text-sm text-muted-foreground/60 text-center py-4">Sin datos todavía.</p>
      ) : (
        <ol class="flex flex-col gap-2.5">
          {topCommentedPosts.map((p, i) => (
            <li class="flex items-center gap-3">
              <span class="text-xs font-bold tabular-nums text-muted-foreground/40 w-4 shrink-0">{i + 1}</span>
              <div class="flex-1 min-w-0">
                <a href={`/blog/${p.slug}`} class="text-sm font-medium truncate hover:text-primary transition-colors block" title={p.title}>
                  {p.title}
                </a>
              </div>
              <span class="shrink-0 text-xs font-semibold tabular-nums text-muted-foreground">{p.count} 💬</span>
            </li>
          ))}
        </ol>
      )}
    </div>

    <!-- Top reacted posts -->
    <div class="bg-card border border-border/60 rounded-xl p-5">
      <p class="text-sm font-semibold mb-4">Posts más reaccionados</p>
      {topReactedPosts.length === 0 ? (
        <p class="text-sm text-muted-foreground/60 text-center py-4">Sin datos todavía.</p>
      ) : (
        <ol class="flex flex-col gap-2.5">
          {topReactedPosts.map((p, i) => (
            <li class="flex items-center gap-3">
              <span class="text-xs font-bold tabular-nums text-muted-foreground/40 w-4 shrink-0">{i + 1}</span>
              <div class="flex-1 min-w-0">
                <a href={`/blog/${p.slug}`} class="text-sm font-medium truncate hover:text-primary transition-colors block" title={p.title}>
                  {p.title}
                </a>
              </div>
              <span class="shrink-0 text-xs font-semibold tabular-nums text-muted-foreground">{p.count} ❤️</span>
            </li>
          ))}
        </ol>
      )}
    </div>

    <!-- Top viewed posts -->
    <div class="bg-card border border-border/60 rounded-xl p-5">
      <p class="text-sm font-semibold mb-4">Posts más vistos</p>
      {topViewedPosts.length === 0 ? (
        <p class="text-sm text-muted-foreground/60 text-center py-4">Sin datos todavía.</p>
      ) : (
        <ol class="flex flex-col gap-2.5">
          {topViewedPosts.map((p, i) => (
            <li class="flex items-center gap-3">
              <span class="text-xs font-bold tabular-nums text-muted-foreground/40 w-4 shrink-0">{i + 1}</span>
              <div class="flex-1 min-w-0">
                <a href={`/blog/${p.slug}`} class="text-sm font-medium truncate hover:text-primary transition-colors block" title={p.title}>
                  {p.title}
                </a>
              </div>
              <span class="shrink-0 text-xs font-semibold tabular-nums text-muted-foreground">{p._count.views} 👁</span>
            </li>
          ))}
        </ol>
      )}
    </div>

    <!-- Top commenters -->
    <div class="bg-card border border-border/60 rounded-xl p-5">
      <p class="text-sm font-semibold mb-4">Usuarios más activos</p>
      {topCommenters.length === 0 ? (
        <p class="text-sm text-muted-foreground/60 text-center py-4">Sin datos todavía.</p>
      ) : (
        <ol class="flex flex-col gap-2.5">
          {topCommenters.map((u, i) => (
            <li class="flex items-center gap-3">
              <span class="text-xs font-bold tabular-nums text-muted-foreground/40 w-4 shrink-0">{i + 1}</span>
              <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary text-xs font-bold">
                {getInitials(u.name)}
              </div>
              <span class="flex-1 text-sm font-medium truncate">{u.name}</span>
              <span class="shrink-0 text-xs font-semibold tabular-nums text-muted-foreground">{u.count} 💬</span>
            </li>
          ))}
        </ol>
      )}
    </div>
  </div>

  <!-- ── Row 4: Recent activity ─────────────────────────── -->
  <div class="grid lg:grid-cols-3 gap-6">

    <!-- Recent users -->
    <div class="bg-card border border-border/60 rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold">Últimos usuarios</h2>
        <a href="/admin/users" class="text-xs text-primary hover:underline">Ver todos →</a>
      </div>
      {recentUsers.length === 0 ? (
        <p class="text-sm text-muted-foreground py-4 text-center">Sin usuarios todavía.</p>
      ) : (
        <ul class="divide-y divide-border/40">
          {recentUsers.map(u => (
            <li class="flex items-center gap-3 py-2.5">
              <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary text-xs font-bold">
                {getInitials(u.name)}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium truncate">{u.name}</p>
                <p class="text-xs text-muted-foreground truncate">{u.email}</p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <span class={`text-xs rounded-full px-2 py-0.5 font-medium ${
                  u.role.name === "ADMIN" ? "bg-primary/10 text-primary" : "bg-secondary/50 text-muted-foreground"
                }`}>{u.role.name}</span>
                <span class="text-xs text-muted-foreground hidden sm:inline">{formatDate(u.createdAt)}</span>
              </div>
            </li>
          ))}
        </ul>
      )}
    </div>

    <!-- Recent comments -->
    <div class="bg-card border border-border/60 rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold">Últimos comentarios</h2>
        <a href="/admin/comments" class="text-xs text-primary hover:underline">Ver todos →</a>
      </div>
      {recentComments.length === 0 ? (
        <p class="text-sm text-muted-foreground py-4 text-center">Sin comentarios todavía.</p>
      ) : (
        <ul class="divide-y divide-border/40">
          {recentComments.map(c => (
            <li class="py-2.5">
              <div class="flex items-center justify-between gap-2 mb-0.5">
                <span class="text-sm font-medium">{c.user.name}</span>
                <span class="text-xs text-muted-foreground shrink-0">{formatDate(c.createdAt)}</span>
              </div>
              <p class="text-xs text-muted-foreground truncate">{c.content}</p>
              <a href={`/blog/${c.post.slug}`} class="text-xs text-primary hover:underline mt-0.5 inline-block">
                {c.post.slug}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>

    <!-- Activity feed -->
    <div class="bg-card border border-border/60 rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-semibold">Actividad reciente</h2>
        <a href="/admin/audit" class="text-xs text-primary hover:underline">Ver todo →</a>
      </div>
      {recentAuditLogs.length === 0 ? (
        <p class="text-sm text-muted-foreground py-4 text-center">Sin actividad todavía.</p>
      ) : (
        <ul class="flex flex-col gap-2.5">
          {recentAuditLogs.map(log => {
            const cls = actionColor(log.action);
            return (
              <li class="flex items-start gap-2.5 min-w-0">
                <span class={`mt-0.5 shrink-0 rounded-full px-1.5 py-0.5 text-[10px] font-semibold uppercase ${cls}`}>
                  {log.action}
                </span>
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-muted-foreground truncate">
                    <span class="font-medium text-foreground">{log.entity}</span>
                    {log.entityId && <span class="opacity-50"> · {log.entityId.slice(0, 16)}</span>}
                  </p>
                  <p class="text-[10px] text-muted-foreground/60 truncate">
                    {log.userEmail ?? "Sistema"} · {new Date(log.createdAt).toLocaleString("es-ES", { day: "numeric", month: "short", hour: "2-digit", minute: "2-digit" })}
                  </p>
                </div>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </div>

</AdminLayout>
