---
export const prerender = false;
import BaseLayout from "@/layouts/main.astro";

const { social_github, social_linkedin, portfolio_url } = Astro.locals.settings;

const GITHUB_ICON   = "M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z";
const LINKEDIN_ICON = "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z";

type SocialLink = { name: string; href: string; icon: string };
const socialLinks: SocialLink[] = [
  ...(social_github   ? [{ name: "GitHub",  href: social_github,   icon: GITHUB_ICON   }] : []),
  ...(social_linkedin ? [{ name: "LinkedIn", href: social_linkedin, icon: LINKEDIN_ICON }] : []),
];
---

<BaseLayout
  title="Sobre mí"
  description="Soy Hugo, desarrollador web junior. Aquí cuento quién soy, por qué escribo y en qué proyectos estoy trabajando."
>
  <section class="mx-auto max-w-3xl py-20 px-4">
    <header class="mb-12 text-center">
      <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight mb-4 reveal">Sobre mí</h1>
      <p class="text-lg text-muted-foreground reveal stagger-1">
        Un espacio para contarte quién soy y qué hago.
      </p>
      {portfolio_url && (
        <div class="mt-6 reveal stagger-2">
          <a
            href={portfolio_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-11 items-center justify-center rounded-full bg-primary px-8 text-sm font-medium text-primary-foreground modern-hover modern-scale-sm hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
          >
            Ver mi portfolio
          </a>
        </div>
      )}
      {socialLinks.length > 0 && (
        <div class="mt-6 flex justify-center gap-4 reveal stagger-3">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-10 w-10 items-center justify-center rounded-full bg-secondary/30 border border-border/60 text-muted-foreground/80 modern-scale-sm modern-hover hover:bg-secondary/50 hover:text-foreground hover:border-primary/50 shadow-sm"
              aria-label={social.name}
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d={social.icon} />
              </svg>
            </a>
          ))}
        </div>
      )}
    </header>

    <section class="mb-12 reveal stagger-3">
      <h2 class="text-2xl font-bold">Quién soy</h2>
      <p>
        ¡Hola! Soy <strong>Hugo</strong>, desarrollador web junior desde hace unos meses. Estoy
        aprendiendo cada día y descubriendo lo que significa trabajar en proyectos reales.
      </p>
      <p>
        Este blog es mi espacio para documentar mi progreso, reflexionar sobre lo que voy
        aprendiendo y compartir mis experiencias mientras crezco como desarrollador.
      </p>
    </section>

    <section class="mb-12 reveal stagger-4">
      <h2 class="text-2xl font-bold">Por qué escribo</h2>
      <p>
        Escribo en este blog para mostrar mi progreso como desarrollador, compartir ideas, proyectos
        y aprendizajes. Quiero que sea un espacio donde pueda ver mi evolución y, al mismo tiempo,
        inspirar o ayudar a otros que estén empezando.
      </p>
    </section>

    <section class="reveal stagger-5">
      <h2 class="text-2xl font-bold">Mis proyectos e ideas</h2>
      <p>
        Aquí comparto los proyectos en los que estoy trabajando, ideas que quiero explorar y
        soluciones que voy encontrando. Cada entrada refleja mi camino como desarrollador junior y
        las lecciones que voy aprendiendo en el proceso.
      </p>
    </section>
  </section>
</BaseLayout>
