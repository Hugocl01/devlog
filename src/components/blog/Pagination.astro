---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string; // e.g. "/blog" or "/updates"
}

const { currentPage, totalPages, baseUrl } = Astro.props;

if (totalPages <= 1) return;

const pageUrl = (p: number) => (p === 1 ? baseUrl : `${baseUrl}?page=${p}`);

// Build the list of page slots: numbers or "..." gaps
function buildPages(current: number, total: number): (number | "...")[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | "...")[] = [1];
  if (current > 3) pages.push("...");
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push("...");
  pages.push(total);
  return pages;
}

const pages = buildPages(currentPage, totalPages);
---

<nav aria-label="Paginación" class="flex items-center justify-center gap-1.5 py-10">
  <!-- Prev -->
  {currentPage > 1 ? (
    <a
      href={pageUrl(currentPage - 1)}
      class="inline-flex h-9 items-center gap-1 rounded-lg border border-border/60 bg-card/40 px-3 text-sm text-muted-foreground transition-colors hover:border-primary/50 hover:text-foreground hover:bg-secondary/40"
      aria-label="Página anterior"
    >
      ← Anterior
    </a>
  ) : (
    <span class="inline-flex h-9 items-center gap-1 rounded-lg border border-border/30 bg-card/20 px-3 text-sm text-muted-foreground/40 cursor-not-allowed select-none">
      ← Anterior
    </span>
  )}

  <!-- Page numbers -->
  <div class="flex items-center gap-1">
    {pages.map((p) =>
      p === "..." ? (
        <span class="flex h-9 w-9 items-center justify-center text-sm text-muted-foreground/50 select-none">
          …
        </span>
      ) : p === currentPage ? (
        <span
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-primary text-sm font-semibold text-primary-foreground"
          aria-current="page"
          aria-label={`Página ${p}`}
        >
          {p}
        </span>
      ) : (
        <a
          href={pageUrl(p as number)}
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border/60 bg-card/40 text-sm text-muted-foreground transition-colors hover:border-primary/50 hover:text-foreground hover:bg-secondary/40"
          aria-label={`Ir a la página ${p}`}
        >
          {p}
        </a>
      )
    )}
  </div>

  <!-- Next -->
  {currentPage < totalPages ? (
    <a
      href={pageUrl(currentPage + 1)}
      class="inline-flex h-9 items-center gap-1 rounded-lg border border-border/60 bg-card/40 px-3 text-sm text-muted-foreground transition-colors hover:border-primary/50 hover:text-foreground hover:bg-secondary/40"
      aria-label="Página siguiente"
    >
      Siguiente →
    </a>
  ) : (
    <span class="inline-flex h-9 items-center gap-1 rounded-lg border border-border/30 bg-card/20 px-3 text-sm text-muted-foreground/40 cursor-not-allowed select-none">
      Siguiente →
    </span>
  )}
</nav>
