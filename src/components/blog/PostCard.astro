---
interface Props {
  slug: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  readingTime?: number;
  class?: string;
}

import { Badge } from "../ui/badge";
import { ChevronRight } from "@lucide/astro";
import { tagUrl } from "@/utils/tag";

const { slug, title, description, date, tags, readingTime, class: className } = Astro.props;
const url = `/blog/${slug}`;

const formattedDate = date.toLocaleDateString("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article
  class:list={[
    "group relative flex h-full flex-col rounded-lg border border-border bg-card p-6 transition-all duration-500 ease-premium",
    "hover:shadow-2xl hover:border-primary/30 hover:-translate-y-1 hover:scale-[1.01]",
    "focus-within:ring-2 focus-within:ring-primary focus-within:ring-offset-2 reveal",
    className,
  ]}
>
  <div class="flex h-full flex-col">
    <h2
      id={`title-${slug}`}
      class="mb-2 text-balance text-2xl font-bold tracking-tight text-foreground
             transition-colors group-hover:text-primary"
    >
      <a href={url} class="after:absolute after:inset-0 focus:outline-none">
        {title}
      </a>
    </h2>

    <time datetime={date.toISOString()} class="mb-4 block text-sm text-muted-foreground">
      {formattedDate}
      {readingTime && ` • ${readingTime} min de lectura`}
    </time>

    <p class="mb-6 text-pretty text-base text-muted-foreground line-clamp-4">
      {description}
    </p>

    <div class="mt-auto flex flex-col items-start gap-4 cursor-pointer">
      <div class="flex flex-wrap gap-2">
        {
          tags?.map((tag) => (
            <a
              href={`/tags/${tagUrl(tag)}`}
              class="relative z-20 hover:opacity-80 transition-all duration-300 hover:scale-110 active:scale-95"
            >
              <Badge variant="secondary">{tag}</Badge>
            </a>
          ))
        }
      </div>

      <span
        class="inline-flex items-center gap-1 text-sm font-medium text-primary
               transition-all group-hover:gap-2"
        aria-hidden="true"
      >
        Leer más
        <ChevronRight
          class="h-4 w-4 transition-transform duration-300 ease-premium group-hover:translate-x-1"
          stroke-width="2.5"
        />
      </span>
    </div>
  </div>
</article>
