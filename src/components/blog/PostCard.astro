---
interface Props {
  id: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  cover?: any;
  readingTime?: number;
  class?: string;
}

import { Badge } from "../ui/badge";
import { ChevronRight } from "@lucide/astro";
import { Image } from "astro:assets";
import { tagUrl } from "@/utils/tag";

const { id, title, description, date, tags, cover, readingTime, class: className } = Astro.props;
const url = `/blog/${id}`;

const formattedDate = date.toLocaleDateString("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article
  class:list={[
    "group relative flex h-full flex-col sm:flex-row rounded-lg border border-border bg-card overflow-hidden transition-all duration-500 ease-premium",
    "hover:shadow-premium hover:border-primary/30 hover:-translate-y-1 hover:scale-[1.05]",
    "focus-within:ring-2 focus-within:ring-primary focus-within:ring-offset-2 reveal",
    className,
  ]}
>
  {
    cover && (
      <div class="relative w-full sm:w-1/3 aspect-video sm:aspect-auto overflow-hidden">
        <Image
          src={cover}
          alt={title}
          width={400}
          height={300}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
          transition:name={`img-${id}`}
        />
      </div>
    )
  }

  <div class="flex flex-1 h-full flex-col p-6">
    <h2
      id={`title-${id}`}
      class="mb-2 text-balance text-2xl font-bold tracking-tight text-foreground
             transition-colors group-hover:text-primary"
      transition:name={`title-${id}`}
    >
      <a href={url} class="after:absolute after:inset-0 focus:outline-none">
        {title}
      </a>
    </h2>

    <time datetime={date.toISOString()} class="mb-4 block text-sm text-muted-foreground">
      {formattedDate}
      {readingTime && ` • ${readingTime} min de lectura`}
    </time>

    <p class="mb-6 text-pretty text-base text-muted-foreground line-clamp-4">
      {description}
    </p>

    <div class="mt-auto flex flex-col items-start gap-4 cursor-pointer">
      <div class="flex flex-wrap gap-2">
        {
          tags?.map((tag) => (
            <a
              href={`/tags/${tagUrl(tag)}`}
              class="relative z-20 hover:opacity-80 transition-all duration-300 hover:scale-105 active:scale-95"
            >
              <Badge variant="secondary">{tag}</Badge>
            </a>
          ))
        }
      </div>

      <span
        class="inline-flex items-center gap-1 text-sm font-medium text-primary
               transition-all group-hover:gap-2"
        aria-hidden="true"
      >
        Leer más
        <ChevronRight
          class="h-4 w-4 transition-transform duration-300 ease-premium group-hover:translate-x-1"
          stroke-width="2.5"
        />
      </span>
    </div>
  </div>
</article>
