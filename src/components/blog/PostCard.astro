---
import type { ImageMetadata } from "astro";
import type { TagWithColor } from "@/types/tag";

interface Props {
  id: string;
  title: string;
  description: string;
  date: Date;
  tags: TagWithColor[];
  cover?: string | ImageMetadata;
  readingTime?: number;
  class?: string;
}

import { Badge } from "../ui/badge";
import { ChevronRight } from "@lucide/astro";
import { Image } from "astro:assets";
import { tagUrl } from "@/utils/tag";
import { formatDate, isoDate } from "@/utils/date";

const { id, title, description, date, tags, cover, readingTime, class: className } = Astro.props;
const url = `/blog/${id}`;
const titleId = `title-${id}`;

const formattedDate = formatDate(date);
const publishedDate = isoDate(date);
---

<article
  class:list={[
    "group relative flex h-full flex-col rounded-2xl border border-border/50 bg-card/40 backdrop-blur-sm overflow-hidden reveal modern-scale-lg modern-hover",
    "hover:border-primary/50 hover:bg-secondary/30",
    "focus-within:ring-2 focus-within:ring-primary focus-within:ring-offset-2 reveal",
    className,
  ]}
>
  <a
    href={url}
    aria-labelledby={titleId}
    class="absolute inset-0 z-10 rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-card"
  />
  {
    cover && (
      <div class="relative w-full aspect-video overflow-hidden">
        {typeof cover === "string" ? (
          <img
            src={cover}
            alt={title}
            width={400}
            height={300}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
            transition:name={`img-${id}`}
          />
        ) : (
          <Image
            src={cover}
            alt={title}
            width={400}
            height={300}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
            transition:name={`img-${id}`}
          />
        )}
      </div>
    )
  }

  <div class="flex flex-1 h-full flex-col p-6">
    <h2
      id={titleId}
      class="mb-2 text-balance text-2xl font-bold tracking-tight text-foreground
             transition-colors group-hover:text-primary"
      transition:name={`title-${id}`}
    >
      {title}
    </h2>

    <time datetime={publishedDate} class="mb-4 block text-sm text-muted-foreground">
      {formattedDate}
      {readingTime && ` • ${readingTime} min de lectura`}
    </time>

    <p class="mb-6 text-pretty text-base text-muted-foreground line-clamp-4">
      {description}
    </p>

    <div class="mt-auto flex flex-col items-start gap-4 cursor-pointer">
      <div class="flex flex-wrap gap-2">
        {
          tags?.map((tag) => (
            <a
              href={`/tags/${tagUrl(tag.name)}`}
              class="relative z-20 hover:opacity-80 transition-all duration-300 hover:scale-105 active:scale-95"
            >
              {tag.color ? (
                <span
                  class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium transition-all duration-300"
                  style={`background-color:${tag.color}20;border-color:${tag.color}50;color:${tag.color}`}
                >
                  {tag.name}
                </span>
              ) : (
                <Badge variant="secondary" className="bg-primary/5 text-primary/70 border-primary/10 hover:bg-primary/10 hover:text-primary transition-all duration-300">
                  {tag.name}
                </Badge>
              )}
            </a>
          ))
        }
      </div>

      <span
        class="inline-flex items-center gap-1 text-sm font-medium text-primary
               transition-all group-hover:gap-2"
        aria-hidden="true"
      >
        Leer más
        <ChevronRight
          class="h-4 w-4 transition-transform duration-300 ease-modern group-hover:translate-x-1"
          stroke-width="2.5"
        />
      </span>
    </div>
  </div>
</article>
