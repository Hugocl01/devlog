---
import { ChevronRight } from "@lucide/astro";
import { formatDate } from "@/utils/date";
import { tagUrl } from "@/utils/tag";
import { Badge } from "@/components/ui/badge";
import type { TagWithColor } from "@/types/tag";

interface RelatedPost {
  id: string;
  title: string;
  date: Date;
  tags: TagWithColor[];
  readingTime?: number;
}

interface Props {
  posts: RelatedPost[];
}

const { posts } = Astro.props;
---

{posts.length > 0 && (
  <section class="max-w-3xl mx-auto mt-12 pt-8 border-t border-border/40">
    <h2 class="text-xs font-bold uppercase tracking-widest text-muted-foreground/60 mb-4 reveal">
      Posts relacionados
    </h2>
    <ul class="flex flex-col divide-y divide-border/40">
      {posts.map((post, index) => (
        <li class={`reveal stagger-${index + 1}`}>
          <div class="group flex items-start justify-between gap-4 py-4">
            <div class="flex flex-col gap-1.5 min-w-0 flex-1">
              <a
                href={`/blog/${post.id}`}
                class="font-semibold text-foreground hover:text-primary transition-colors duration-200 line-clamp-2 leading-snug"
              >
                {post.title}
              </a>
              <div class="flex flex-wrap gap-1.5">
                {(post.tags ?? []).slice(0, 3).map((tag) => (
                  <a
                    href={`/tags/${tagUrl(tag.name)}`}
                    class="relative hover:opacity-80 transition-all duration-300 hover:scale-105 active:scale-95"
                  >
                    {tag.color ? (
                      <span
                        class="inline-flex items-center rounded-full border px-1.5 py-0 text-[10px] font-medium"
                        style={`background-color:${tag.color}20;border-color:${tag.color}50;color:${tag.color}`}
                      >
                        {tag.name}
                      </span>
                    ) : (
                      <Badge variant="secondary" className="text-[10px] px-1.5 py-0 bg-primary/5 text-primary/70 border-primary/10 hover:bg-primary/10 hover:text-primary transition-all duration-300">
                        {tag.name}
                      </Badge>
                    )}
                  </a>
                ))}
              </div>
            </div>
            <div class="flex items-center gap-3 shrink-0 text-xs text-muted-foreground/60 mt-0.5">
              <span class="hidden sm:block tabular-nums">{formatDate(post.date)}</span>
              {post.readingTime && <span class="hidden sm:block">{post.readingTime} min</span>}
              <ChevronRight class="h-4 w-4 shrink-0 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:text-primary" />
            </div>
          </div>
        </li>
      ))}
    </ul>
  </section>
)}
