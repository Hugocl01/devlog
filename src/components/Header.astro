---
import { ChevronsLeftRightEllipsis } from "@lucide/astro";
import HeaderMenu from "./nav/HeaderMenu";
import { ThemeToggle } from "./ThemeToggle";
import { Search } from "./Search";

const navigation = [
  { name: "Inicio", href: "/" },
  { name: "Blog", href: "/blog" },
  { name: "Etiquetas", href: "/tags" },
  { name: "Acerca de", href: "/about" },
  { name: "Contacto", href: "/contact" },
];
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-md" data-pagefind-ignore>
  <nav class="container mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
    <a href="/" class="flex items-center gap-2 text-lg font-bold" aria-label="Ir al inicio">
      <ChevronsLeftRightEllipsis />
      <span>DevLog</span>
    </a>

    <div class="flex items-center gap-2 sm:gap-4">
      <div class="flex items-center">
        <Search client:load />
      </div>
      <HeaderMenu items={navigation} client:load />
      <ThemeToggle client:load />
    </div>
  </nav>
</header>
