# ═══════════════════════════════════════════════
# .gitignore — DevLog
#
# Ficheros con plantilla de ejemplo (copiar y rellenar):
#   .env                  ←  .env.example
#   ecosystem.config.cjs  ←  ecosystem.config.example.cjs
#   nginx/devlog.conf     ←  nginx/devlog.conf.example
# ═══════════════════════════════════════════════

# ─── Construcción ──────────────────────────────
dist/
.astro/

# ─── Dependencias ──────────────────────────────
node_modules/

# ─── Variables de entorno ──────────────────────
# Usar .env.example como plantilla
.env
.env.local
.env.*.local
.env.production
.env.staging

# ─── PM2 ───────────────────────────────────────
# Usar ecosystem.config.example.cjs como plantilla
ecosystem.config.cjs

# ─── Nginx ─────────────────────────────────────
# Usar nginx/devlog.conf.example como plantilla
nginx/devlog.conf

# ─── Archivos subidos por usuarios ─────────────
# Solo se versiona el directorio vacío mediante .gitkeep
public/uploads/*
!public/uploads/.gitkeep

# ─── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Certificados y claves SSL ─────────────────
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# ─── Prisma generado ───────────────────────────
/src/generated/prisma

# ─── Sistema operativo ─────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editores e IDEs ───────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
