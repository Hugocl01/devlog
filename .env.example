# ══════════════════════════════════════════════
# PLANTILLA DE VARIABLES DE ENTORNO
# Copia este archivo como .env y rellena los valores.
# Este archivo SÍ se sube a Git (no contiene secretos reales).
# ══════════════════════════════════════════════

# ─── Entorno ───────────────────────────────────
# "development" en local | "production" en el VPS
NODE_ENV="development"

# ─── Servidor ──────────────────────────────────
# Desarrollo:  HOST=localhost  PORT=4321  SITE_URL=http://localhost:4321
# Producción:  HOST=0.0.0.0   PORT=4321  SITE_URL=https://tudominio.com
#
# HOST=0.0.0.0 es necesario en el VPS para que Nginx pueda hacer el proxy.
HOST="localhost"
PORT="4321"
SITE_URL="http://localhost:4321"

# ─── Base de datos ─────────────────────────────
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
#
# Desarrollo:  postgresql://devlog_user:contraseña@localhost:5432/devlog
# Producción:  postgresql://devlog_user:contraseña@localhost:5432/devlog
#              (en el VPS el host también es localhost porque la BD corre en el mismo servidor)
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@localhost:5432/devlog?schema=public"

# ─── Autenticación JWT ─────────────────────────
# Genera una clave segura con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# IMPORTANTE: usa claves distintas en desarrollo y producción.
JWT_SECRET="CLAVE_SECRETA_MUY_LARGA_Y_ALEATORIA_MINIMO_32_CARACTERES"
JWT_EXPIRES_IN="7d"

# ─── Email ─────────────────────────────────────
# Proveedor: Resend (resend.com) — gratis hasta 3.000 emails/mes
# Crea una cuenta y genera una API key en resend.com.
#
# Desarrollo: usa onboarding@resend.dev como sender (sin dominio verificado).
#   Solo puede enviar al email del propietario de la cuenta Resend.
# Producción: verifica tu dominio en Resend y usa noreply@tudominio.com.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Desarrollo:  EMAIL_FROM="DevLog <onboarding@resend.dev>"
# Producción:  EMAIL_FROM="DevLog <noreply@tudominio.com>"  (dominio verificado en Resend)
EMAIL_FROM="DevLog <onboarding@resend.dev>"

# ─── GitHub OAuth ──────────────────────────────
# Crea una OAuth App en: github.com/settings/developers → "New OAuth App"
#
# Rellena así:
#   Application name:        DevLog
#   Homepage URL:            https://tudominio.com
#   Authorization callback URL: https://tudominio.com/api/auth/github/callback
#
# En desarrollo usa http://localhost:4321/api/auth/github/callback
# (puedes crear una app separada de desarrollo o cambiar la URL en la misma app)
GITHUB_CLIENT_ID="Ov23liXXXXXXXXXXXXXX"
GITHUB_CLIENT_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
